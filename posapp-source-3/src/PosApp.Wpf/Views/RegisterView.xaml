<UserControl x:Class="PosApp.Wpf.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Cash Register" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Track opening cash, paid in/out movements, X reports, and end-of-day close"
                           Style="{StaticResource Muted}"/>
            </StackPanel>
            <Border Grid.Column="1" x:Name="StatusBorder" CornerRadius="16" Padding="14,7"
                    Background="{DynamicResource SurfaceMutedBrush}" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="No open session" FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Opening Cash" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="OpeningText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="Cash Sales" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="CashSalesText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="Cash In / Out" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="MovementsText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0"
                    Background="{DynamicResource InfoSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="Expected in Drawer" Style="{StaticResource Muted}"
                               Foreground="{DynamicResource InfoTextBrush}"/>
                    <TextBlock x:Name="ExpectedText" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource InfoTextBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="OpenButton" Content="Open Register" Style="{StaticResource SuccessButton}"
                    Click="Open_Click" Margin="0,0,8,0"/>
            <Button x:Name="CashInButton" Content="Cash In" Style="{StaticResource OutlineButton}"
                    Click="CashIn_Click" Margin="0,0,8,0"/>
            <Button x:Name="CashOutButton" Content="Cash Out" Style="{StaticResource OutlineButton}"
                    Click="CashOut_Click" Margin="0,0,8,0"/>
            <Button x:Name="ReportButton" Content="X Report" Style="{StaticResource OutlineButton}"
                    Click="Report_Click" Margin="0,0,8,0"/>
            <Button x:Name="CloseButton" Content="Close &amp; Z Report" Style="{StaticResource DangerButton}"
                    Click="Close_Click"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock Text="Current Session Movements" DockPanel.Dock="Top"
                               FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="MovementGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding LocalTime, StringFormat='{}{0:dd MMM HH:mm}'}" Width="120"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding SignedAmount, StringFormat='৳ {0:+0.00;-0.00;0.00}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock Text="Recent Register Sessions (double-click to view)" DockPanel.Dock="Top"
                               FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="SessionGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="SessionGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Opened" Binding="{Binding OpenedLocal, StringFormat='{}{0:dd MMM HH:mm}'}" Width="125"/>
                            <DataGridTextColumn Header="Closed" Binding="{Binding ClosedLocal, StringFormat='{}{0:dd MMM HH:mm}'}" Width="125"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="85"/>
                            <DataGridTextColumn Header="Expected" Binding="{Binding Expected, StringFormat='৳ {0:0.00}'}" Width="100"/>
                            <DataGridTextColumn Header="Variance" Binding="{Binding Variance, StringFormat='৳ {0:+0.00;-0.00;0.00}'}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
