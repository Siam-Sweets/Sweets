<UserControl x:Class="PosApp.Wpf.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- Left: product catalog -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         Padding="12,10" FontSize="15"/>
                <TextBlock Grid.Column="0" Text="{DynamicResource POS_Search}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           IsHitTestVisible="False"
                           Visibility="{Binding SearchPlaceholderVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Grid.Column="1" Content="🔍" Style="{StaticResource OutlineButton}" Margin="8,0,0,0"
                        Width="44" Click="Search_Click"/>
                <Button Grid.Column="2" Content="{DynamicResource POS_Weigh}" Style="{StaticResource OutlineButton}"
                        Margin="8,0,0,0" Padding="16,8"
                        Click="Weigh_Click"
                        Visibility="{Binding IsScaleConnected, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>

            <!-- Category strip -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Categories}" Margin="0,0,0,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Name}"
                                Style="{StaticResource OutlineButton}"
                                Margin="0,0,8,0" Padding="14,8"
                                Click="Category_Click" Tag="{Binding Id}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Product grid -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ProductTile}" Click="Product_Click" Tag="{Binding}">
                                    <StackPanel Margin="8">
                                        <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="6" Height="56" Margin="0,0,0,8">
                                            <TextBlock Text="📦" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Price, Converter={StaticResource Money}, ConverterParameter=৳}"
                                                   FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock Text="{Binding StockQuantity, StringFormat='Stock: {0}'}"
                                                   FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Right: cart + totals -->
        <Border Grid.Column="1" Background="{DynamicResource CardBrush}" Margin="0,16,16,16" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource POS_Cart}" FontSize="18" FontWeight="SemiBold"/>
                    <Button Grid.Column="1" Content="{DynamicResource POS_Recall}" Style="{StaticResource OutlineButton}"
                            Padding="10,6" Margin="0,0,4,0" Click="Recall_Click"/>
                    <Button Grid.Column="2" Content="🗑" Style="{StaticResource OutlineButton}"
                            Padding="10,6" Margin="4,0,0,0" Click="Clear_Click" ToolTip="Clear cart"/>
                </Grid>

                <!-- Customer selector -->
                <Border Grid.Row="1" Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,12"
                        MouseLeftButtonDown="Customer_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="👤" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding CustomerDisplay}" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="Medium"/>
                        <TextBlock Grid.Column="2" Text="›" FontSize="16" Foreground="{DynamicResource TextMutedBrush}"/>
                    </Grid>
                </Border>

                <!-- Cart items -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                    <ListView ItemsSource="{Binding CartLines}" Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ProductName}" FontWeight="Medium" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Button Width="22" Height="22" Padding="0" FontSize="14"
                                                    Content="−" Click="QtyMinus_Click" Tag="{Binding}"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat=' {0:0.###} '}"
                                                       VerticalAlignment="Center" Margin="6,0"/>
                                            <Button Width="22" Height="22" Padding="0" FontSize="14"
                                                    Content="+" Click="QtyPlus_Click" Tag="{Binding}"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat=' @ {0:0.00}'}"
                                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0">
                                        <Run Text="৳ "/><Run Text="{Binding LineTotal, Mode=OneWay, StringFormat='0.00'}"/>
                                    </TextBlock>
                                    <Button Grid.Column="2" Width="22" Height="22" Padding="0" FontSize="12"
                                            Content="✕" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource DangerBrush}"
                                            Click="RemoveLine_Click" Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>

                <!-- Totals -->
                <StackPanel Grid.Row="3" Margin="0,8,0,12">
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource POS_Subtotal}" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Subtotal, StringFormat='৳ {0:0.00}'}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource POS_Discount}" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding DiscountTotal, StringFormat='- ৳ {0:0.00}'}"
                                   Foreground="{StaticResource DangerBrush}"/>
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource POS_Tax}" Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding TaxTotal, StringFormat='৳ {0:0.00}'}"/>
                    </Grid>
                    <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource POS_Total}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="৳ "/><Run Text="{Binding Total, Mode=OneWay, StringFormat='0.00'}"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Action buttons -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{DynamicResource POS_Suspend}" Style="{StaticResource OutlineButton}"
                            Margin="0,0,4,0" Padding="0,12" Click="Suspend_Click"/>
                    <Button Grid.Column="1" Content="{DynamicResource POS_Checkout}" Style="{StaticResource SuccessButton}"
                            Margin="4,0,0,0" Padding="0,12" FontSize="15" Click="Checkout_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
