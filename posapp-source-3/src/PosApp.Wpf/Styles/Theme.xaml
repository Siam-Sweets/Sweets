<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:options="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- Color palette: flat, modern, Material-inspired -->
    <Color x:Key="PrimaryColor">#2D7FF9</Color>
    <Color x:Key="PrimaryDarkColor">#1A5FBF</Color>
    <Color x:Key="AccentColor">#F59E0B</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="SidebarColor">#1E293B</Color>
    <Color x:Key="SidebarActiveColor">#0F172A</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="BackgroundLight">#F1F5F9</Color>
    <Color x:Key="TextDark">#0F172A</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="InputColor">#FFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#F1F5F9</Color>
    <Color x:Key="SurfaceHoverColor">#F8FAFC</Color>
    <Color x:Key="AlternateRowColor">#F8FAFC</Color>
    <Color x:Key="SelectionColor">#DBEAFE</Color>
    <Color x:Key="SuccessSurfaceColor">#F0FDF4</Color>
    <Color x:Key="SuccessTextColor">#15803D</Color>
    <Color x:Key="DangerSurfaceColor">#FEF2F2</Color>
    <Color x:Key="DangerTextColor">#DC2626</Color>
    <Color x:Key="InfoSurfaceColor">#EFF6FF</Color>
    <Color x:Key="InfoTextColor">#2563EB</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundLight}" options:Freeze="False"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}" options:Freeze="False"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" options:Freeze="False"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="InputBrush" Color="{StaticResource InputColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="AlternateRowBrush" Color="{StaticResource AlternateRowColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource SelectionColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SuccessSurfaceBrush" Color="{StaticResource SuccessSurfaceColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurfaceColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerTextColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="InfoSurfaceBrush" Color="{StaticResource InfoSurfaceColor}" options:Freeze="False"/>
    <SolidColorBrush x:Key="InfoTextBrush" Color="{StaticResource InfoTextColor}" options:Freeze="False"/>

    <!-- Typography -->
    <FontFamily x:Key="DefaultFont">Segoe UI, Inter, Noto Sans, sans-serif</FontFamily>
    <FontFamily x:Key="BengaliFont">Noto Sans Bengali, SolaimanLipi, SutonnyMJ, Segoe UI</FontFamily>

    <!-- Sizes -->
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
    <Thickness x:Key="PagePadding">24</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>

    <Style x:Key="PageTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
    </Style>

</ResourceDictionary>
