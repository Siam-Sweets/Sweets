# Recommended: one JSON secret. Keep this file local and never commit real values.
POSAPP_CLOUD_CONFIG={"tursoDatabaseUrl":"https://YOUR-DATABASE.turso.io","tursoAuthToken":"YOUR_DATABASE_TOKEN","jwtSecret":"AT_LEAST_32_RANDOM_CHARACTERS","registrationKey":"YOUR_PRIVATE_SIGNUP_KEY","autoInitializeSchema":true}

