<UserControl x:Class="PosApp.Wpf.Views.TransfersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Transfer_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Transfer_Help}" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource Common_Refresh}" Style="{StaticResource OutlineButton}"
                    Click="Refresh_Click" Padding="18,9"/>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="{DynamicResource Transfer_Transfers}">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                        <Button Content="{DynamicResource Transfer_New}" Style="{StaticResource PrimaryButton}" Click="New_Click" Margin="0,0,8,0"/>
                        <Button x:Name="DispatchButton" Content="{DynamicResource Transfer_Dispatch}" Style="{StaticResource OutlineButton}" Click="Dispatch_Click" Margin="0,0,8,0" IsEnabled="False"/>
                        <Button x:Name="ReceiveButton" Content="{DynamicResource Transfer_Receive}" Style="{StaticResource OutlineButton}" Click="Receive_Click" Margin="0,0,8,0" IsEnabled="False"/>
                        <Button x:Name="CancelButton" Content="{DynamicResource Transfer_Cancel}" Style="{StaticResource DangerButton}" Click="Cancel_Click" IsEnabled="False"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="1" x:Name="TransferGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionChanged="TransferGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Number}" Binding="{Binding TransferNumber}" Width="145"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Source}" Binding="{Binding SourceStore}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Destination}" Binding="{Binding DestinationStore}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Status}" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Items}" Binding="{Binding ItemCount}" Width="70"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Created}" Binding="{Binding CreatedAt, StringFormat='{}{0:g}'}" Width="145"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Updated}" Binding="{Binding LastActionAt, StringFormat='{}{0:g}'}" Width="145"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" Text="{DynamicResource Transfer_Details}" Style="{StaticResource Heading3}" Margin="0,14,0,8"/>
                    <TextBlock Grid.Row="3" x:Name="TransferAuditText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="4" x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource POS_ProductName}" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Prod_SkuOnly}" Binding="{Binding Sku}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource POS_Quantity}" Binding="{Binding Quantity}" Width="110"/>
                            <DataGridTextColumn Header="{DynamicResource Prod_Unit}" Binding="{Binding Unit}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="{DynamicResource Transfer_InventoryByStore}">
                <Grid Margin="12">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <WrapPanel Margin="0,0,0,12">
                        <TextBlock Text="{DynamicResource Transfer_Store}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="InventoryStoreFilter" Width="220" DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectionChanged="InventoryFilter_Changed"/>
                        <TextBox x:Name="InventorySearch" Width="240" Margin="12,0,8,0" TextChanged="InventorySearch_TextChanged"/>
                        <Button Content="{DynamicResource Common_Refresh}" Style="{StaticResource OutlineButton}" Click="InventoryRefresh_Click"/>
                    </WrapPanel>
                    <DataGrid Grid.Row="1" x:Name="InventoryGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Store}" Binding="{Binding StoreName}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Store_Code}" Binding="{Binding StoreCode}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource POS_ProductName}" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Prod_SkuOnly}" Binding="{Binding Sku}" Width="130"/>
                            <DataGridTextColumn Header="{DynamicResource Transfer_Stock}" Binding="{Binding StockQuantity}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Prod_Unit}" Binding="{Binding Unit}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource Prod_LowStock}" Binding="{Binding LowStockThreshold}" Width="110"/>
                            <DataGridCheckBoxColumn Header="{DynamicResource Transfer_Low}" Binding="{Binding IsLowStock}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
