<Window x:Class="PosApp.Wpf.Views.StoreEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Store_EditTitle}"
        Width="560" Height="520"
        MinWidth="440" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource Store_EditTitle}"
                   Style="{StaticResource Heading2}"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalFirst"
                      Focusable="False">
            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Store_Code}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,12"/>
                <TextBox x:Name="CodeBox"
                         Grid.Column="1"
                         Margin="0,0,0,12"
                         MaxLength="24"/>

                <TextBlock Grid.Row="1"
                           Text="{DynamicResource Store_Name}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,12"/>
                <TextBox x:Name="NameBox"
                         Grid.Row="1" Grid.Column="1"
                         Margin="0,0,0,12"
                         MaxLength="100"/>

                <TextBlock Grid.Row="2"
                           Text="{DynamicResource Store_Address}"
                           VerticalAlignment="Top"
                           Margin="0,7,12,12"/>
                <TextBox x:Name="AddressBox"
                         Grid.Row="2" Grid.Column="1"
                         Margin="0,0,0,12"
                         MinHeight="90" Height="110"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="500"/>

                <TextBlock Grid.Row="3"
                           Text="{DynamicResource Store_Phone}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <TextBox x:Name="PhoneBox"
                         Grid.Row="3" Grid.Column="1"
                         MaxLength="30"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="{DynamicResource Common_Cancel}"
                    Style="{StaticResource OutlineButton}"
                    IsCancel="True"
                    Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Common_Save}"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
