<UserControl x:Class="PosApp.Wpf.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
        <conv:UtcToLocalConverter x:Key="UtcToLocal"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Purch_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Purch_Subtitle}"
                           Style="{StaticResource Muted}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{DynamicResource Purch_AddSupplier}" Style="{StaticResource OutlineButton}"
                        Click="AddSupplier_Click" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource Purch_NewPurchase}" Style="{StaticResource PrimaryButton}"
                        Click="NewPurchase_Click"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Purch_Documents}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="DocumentCountText" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Purch_Total}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="PurchaseTotalText" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource InfoTextBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Purch_ActiveSuppliers}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="SupplierCountText" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="{DynamicResource Sales_From}" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <DatePicker x:Name="FromPicker" Width="140"/>
            <TextBlock Text="{DynamicResource Sales_To}" VerticalAlignment="Center" Margin="16,0,6,0"/>
            <DatePicker x:Name="ToPicker" Width="140"/>
            <Button Content="{DynamicResource Common_Refresh}" Style="{StaticResource OutlineButton}"
                    Click="Refresh_Click" Margin="12,0,0,0" Padding="14,7"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock Text="{DynamicResource Purch_Posted}" DockPanel.Dock="Top" FontWeight="SemiBold"
                               Margin="16,16,16,8"/>
                    <DataGrid x:Name="PurchasesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="PurchasesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Purch_Document}" Binding="{Binding DocumentNumber}" Width="145"/>
                            <DataGridTextColumn Header="{DynamicResource Sales_Date}" Binding="{Binding DocumentDate, Converter={StaticResource UtcToLocal}, ConverterParameter='dd MMM yyyy HH:mm'}" Width="145"/>
                            <DataGridTextColumn Header="{DynamicResource Purch_Supplier}" Binding="{Binding Supplier.Name}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Purch_Reference}" Binding="{Binding ExternalReference}" Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Rpt_Total}" Binding="{Binding Total, Converter={StaticResource Money}}" Width="105"/>
                            <DataGridTemplateColumn Header="" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource Common_View}" Style="{StaticResource OutlineButton}"
                                                Padding="8,4" Margin="2" Click="ViewPurchase_Click" Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="8,0,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
                        <TextBlock Text="{DynamicResource Purch_Suppliers}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="SupplierSearchBox" TextChanged="SupplierSearch_TextChanged"
                                 Padding="10,7" ToolTip="{DynamicResource Purch_SearchSupplier}"/>
                    </StackPanel>
                    <DataGrid x:Name="SuppliersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Cust_Name}" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Cust_Phone}" Binding="{Binding Phone}" Width="110"/>
                            <DataGridTemplateColumn Header="" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource Common_Edit}" Style="{StaticResource OutlineButton}"
                                                Padding="7,4" Margin="2" Click="EditSupplier_Click" Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
