<Window x:Class="PosApp.Wpf.Views.CloudAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Cloud_AccountTitle}"
        Icon="/PosApp;component/Assets/PosApp.ico"
        Width="720" Height="790" MinWidth="650" MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="26,20">
            <StackPanel>
                <TextBlock Text="{DynamicResource Cloud_AccountTitle}" Foreground="White" FontSize="25" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource Cloud_AccountSubtitle}" Foreground="#DBEAFE" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="AccountTabs" Grid.Row="1" Margin="24" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}">
            <TabItem Header="{DynamicResource Cloud_SignIn}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <TextBlock Text="{DynamicResource Cloud_WorkerAddress}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="LoginApiUrl" Margin="0,5,0,13" Padding="10,8" MaxLength="512"/>
                        <TextBlock Text="{DynamicResource Cloud_UsernameEmail}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="LoginIdentifier" Margin="0,5,0,13" Padding="10,8" MaxLength="255"/>
                        <TextBlock Text="{DynamicResource Cloud_OnlinePassword}" Style="{StaticResource Muted}"/>
                        <PasswordBox x:Name="LoginPassword" Margin="0,5,0,13" Padding="10,8" MaxLength="128"/>
                        <TextBlock Text="{DynamicResource Cloud_OfflinePin}" Style="{StaticResource Muted}"/>
                        <PasswordBox x:Name="LoginOfflinePin" Margin="0,5,0,13" Padding="10,8" MaxLength="12"/>
                        <TextBlock Text="{DynamicResource Cloud_OfflinePinHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource Cloud_DeviceName}" Style="{StaticResource Muted}" Margin="0,13,0,0"/>
                        <TextBox x:Name="LoginDeviceName" Margin="0,5,0,18" Padding="10,8" MaxLength="160"/>
                        <Button Content="{DynamicResource Cloud_SignIn}" Style="{StaticResource PrimaryButton}"
                                Padding="22,11" HorizontalAlignment="Left" Click="Login_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Cloud_CreateOrganization}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,12">
                                <TextBlock Text="{DynamicResource Cloud_OrganizationName}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CreateOrganizationName" Margin="0,5,0,0" Padding="10,8" MaxLength="160"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="{DynamicResource Cloud_StoreName}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CreateStoreName" Margin="0,5,0,0" Padding="10,8" MaxLength="160"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{DynamicResource Cloud_WorkerAddress}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="CreateApiUrl" Margin="0,5,0,12" Padding="10,8" MaxLength="512"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,12">
                                <TextBlock Text="{DynamicResource Cloud_FullName}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CreateFullName" Margin="0,5,0,0" Padding="10,8" MaxLength="100"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="{DynamicResource Cloud_Username}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CreateUsername" Margin="0,5,0,0" Padding="10,8" MaxLength="60"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{DynamicResource Cloud_Email}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="CreateEmail" Margin="0,5,0,12" Padding="10,8" MaxLength="255"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,12">
                                <TextBlock Text="{DynamicResource Cloud_OnlinePassword}" Style="{StaticResource Muted}"/>
                                <PasswordBox x:Name="CreatePassword" Margin="0,5,0,0" Padding="10,8" MaxLength="128"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,12">
                                <TextBlock Text="{DynamicResource Cloud_ConfirmPassword}" Style="{StaticResource Muted}"/>
                                <PasswordBox x:Name="CreatePasswordConfirm" Margin="0,5,0,0" Padding="10,8" MaxLength="128"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,8,18">
                                <TextBlock Text="{DynamicResource Cloud_OfflinePin}" Style="{StaticResource Muted}"/>
                                <PasswordBox x:Name="CreateOfflinePin" Margin="0,5,0,0" Padding="10,8" MaxLength="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,18">
                                <TextBlock Text="{DynamicResource Cloud_DeviceName}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CreateDeviceName" Margin="0,5,0,0" Padding="10,8" MaxLength="160"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="{DynamicResource Cloud_CreateOrganization}" Style="{StaticResource PrimaryButton}"
                                Padding="22,11" HorizontalAlignment="Left" Click="Create_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="22,13">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <ProgressBar x:Name="BusyBar" Height="3" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,0,8"/>
                    <TextBlock x:Name="StatusText" Text="{DynamicResource Cloud_CredentialsProtected}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{DynamicResource Common_Cancel}" Style="{StaticResource OutlineButton}"
                        Padding="18,9" Margin="16,0,0,0" VerticalAlignment="Center" Click="Cancel_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
