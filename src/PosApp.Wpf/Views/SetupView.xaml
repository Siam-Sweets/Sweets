<Window x:Class="PosApp.Wpf.Views.SetupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Setup_WindowTitle}"
        Icon="/PosApp;component/Assets/PosApp.ico"
        Width="820" Height="720" MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="SetupView_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="62" Height="62" Background="White"
                        CornerRadius="16" Padding="4">
                    <Image Source="/PosApp;component/Assets/PosAppLogo.png" Stretch="Uniform"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Setup_Title}" FontSize="25" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="{DynamicResource Setup_Subtitle}" FontSize="13" Foreground="#DBEAFE" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,22">
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Setup_StoreSection}" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="{DynamicResource Setup_StoreHelp}" Style="{StaticResource Muted}" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,7,12">
                                <TextBlock Text="{DynamicResource Setup_StoreName}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="StoreNameBox" MaxLength="100"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="7,0,0,12">
                                <TextBlock Text="{DynamicResource Setup_Phone}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="PhoneBox" MaxLength="50"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <TextBlock Text="{DynamicResource Setup_Address}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="AddressBox" MaxLength="300"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,7,0">
                                <TextBlock Text="{DynamicResource Setup_Currency}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="CurrencyBox" MaxLength="8"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="7,0,0,0">
                                <TextBlock Text="{DynamicResource Setup_ReceiptFooter}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="FooterBox" MaxLength="200"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Setup_AdminSection}" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="{DynamicResource Setup_AdminHelp}" Style="{StaticResource Muted}" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,7,12">
                                <TextBlock Text="{DynamicResource Setup_AdminName}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="AdminNameBox" MaxLength="100"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="7,0,0,12">
                                <TextBlock Text="{DynamicResource Setup_Username}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <TextBox x:Name="UsernameBox" MaxLength="60"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,7,0">
                                <TextBlock Text="{DynamicResource Setup_Pin}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="PinBox" MaxLength="12" PreviewTextInput="PinBox_PreviewTextInput"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="7,0,0,0">
                                <TextBlock Text="{DynamicResource Setup_ConfirmPin}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="ConfirmPinBox" MaxLength="12" PreviewTextInput="PinBox_PreviewTextInput"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="{DynamicResource Set_Language}" Style="{StaticResource Muted}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="LangEn" Content="English" Margin="0,0,16,0" Checked="Language_Checked"/>
                                <RadioButton x:Name="LangBn" Content="বাংলা" Checked="Language_Checked"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="12,0">
                            <TextBlock Text="{DynamicResource Set_Theme}" Style="{StaticResource Muted}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ThemeLight" Content="{DynamicResource Set_Light}" Margin="0,0,16,0" Checked="Theme_Checked"/>
                                <RadioButton x:Name="ThemeDark" Content="{DynamicResource Set_Dark}" Checked="Theme_Checked"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="12,0,0,0">
                            <TextBlock Text="{DynamicResource Setup_DataSafety}" Style="{StaticResource Muted}" Margin="0,0,0,8"/>
                            <CheckBox x:Name="BackupCheck" Content="{DynamicResource Setup_EnableBackup}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" Visibility="Collapsed" Margin="4,14,4,0"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Setup_OfflineNote}"
                           Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="{DynamicResource Setup_Exit}"
                        Style="{StaticResource OutlineButton}" Padding="22,10" Margin="8,0"
                        Click="Exit_Click"/>
                <Button Grid.Column="2" x:Name="FinishButton" Content="{DynamicResource Setup_Finish}"
                        Style="{StaticResource PrimaryButton}" Padding="24,10" Margin="8,0,0,0"
                        Click="Finish_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
