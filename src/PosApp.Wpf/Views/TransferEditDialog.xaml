<Window x:Class="PosApp.Wpf.Views.TransferEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Transfer_New}" Width="760" Height="620"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="{DynamicResource Transfer_Destination}" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1" x:Name="DestinationBox" DisplayMemberPath="Name" SelectedValuePath="Id"/>
        </Grid>
        <DataGrid Grid.Row="1" x:Name="ProductGrid" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="{DynamicResource Transfer_Select}" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                <DataGridTextColumn Header="{DynamicResource POS_ProductName}" Binding="{Binding ProductName}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource Prod_SkuOnly}" Binding="{Binding Sku}" IsReadOnly="True" Width="130"/>
                <DataGridTextColumn Header="{DynamicResource Transfer_Stock}" Binding="{Binding Available}" IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="{DynamicResource POS_Quantity}" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="{DynamicResource Prod_Unit}" Binding="{Binding Unit}" IsReadOnly="True" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBox Grid.Row="2" x:Name="NoteBox" Height="70" Margin="0,14,0,14" AcceptsReturn="True" TextWrapping="Wrap"
                 ToolTip="{DynamicResource Transfer_Note}"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Common_Cancel}" Style="{StaticResource OutlineButton}" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Common_Save}" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
