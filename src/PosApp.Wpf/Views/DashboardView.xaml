<UserControl x:Class="PosApp.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="270"/>
                <RowDefinition Height="300"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Dash_Title}" Style="{StaticResource Heading1}"/>
                    <TextBlock x:Name="PeriodText" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{DynamicResource Dash_Refresh}" Style="{StaticResource OutlineButton}"
                        Padding="18,9" Click="Refresh_Click"/>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
                <Border Style="{StaticResource StatCard}" Margin="0,0,7,0">
                    <StackPanel><TextBlock Text="{DynamicResource Dash_TotalSales}" Style="{StaticResource Muted}"/><TextBlock x:Name="SalesText" FontSize="27" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="7,0">
                    <StackPanel><TextBlock Text="{DynamicResource Rpt_Transactions}" Style="{StaticResource Muted}"/><TextBlock x:Name="TransactionsText" FontSize="27" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="7,0">
                    <StackPanel><TextBlock Text="{DynamicResource Rpt_Profit}" Style="{StaticResource Muted}"/><TextBlock x:Name="ProfitText" FontSize="27" FontWeight="Bold" Margin="0,8,0,0"/></StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="7,0,0,0" Background="{DynamicResource InfoSurfaceBrush}">
                    <StackPanel><TextBlock Text="{DynamicResource Dash_Today}" Foreground="{DynamicResource InfoTextBrush}"/><TextBlock x:Name="TodayText" FontSize="27" FontWeight="Bold" Foreground="{DynamicResource InfoTextBrush}" Margin="0,8,0,0"/></StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,7,0">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Dash_DailySales}" DockPanel.Dock="Top" Style="{StaticResource Heading3}" Margin="16,14,16,8"/>
                        <DataGrid x:Name="DailyGrid" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Sales_Date}" Binding="{Binding Date, StringFormat='{}{0:dd MMM}'}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Transactions}" Binding="{Binding TransactionCount}" Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_NetSales}" Binding="{Binding NetSales, StringFormat={}{0:0.00}}" Width="150"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Profit}" Binding="{Binding GrossProfit, StringFormat={}{0:0.00}}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="7,0,0,0">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Rpt_ByPayment}" DockPanel.Dock="Top" Style="{StaticResource Heading3}" Margin="16,14,16,8"/>
                        <DataGrid x:Name="PaymentGrid" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Dash_Method}" Binding="{Binding Method}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Transactions}" Binding="{Binding Count}" Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Sales_Total}" Binding="{Binding Total, StringFormat={}{0:0.00}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,7,0">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Rpt_TopProducts}" DockPanel.Dock="Top" Style="{StaticResource Heading3}" Margin="16,14,16,8"/>
                        <DataGrid x:Name="TopProductsGrid" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource POS_ProductName}" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource POS_Quantity}" Binding="{Binding QuantitySold}" Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Dash_Revenue}" Binding="{Binding Revenue, StringFormat={}{0:0.00}}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="7,0,0,0">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Rpt_ByHour}" DockPanel.Dock="Top" Style="{StaticResource Heading3}" Margin="16,14,16,8"/>
                        <DataGrid x:Name="HourlyGrid" IsReadOnly="True" AutoGenerateColumns="False" HeadersVisibility="Column" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Dash_Hour}" Binding="{Binding HourLabel}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Transactions}" Binding="{Binding TransactionCount}" Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource Dash_Revenue}" Binding="{Binding Revenue, StringFormat={}{0:0.00}}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
