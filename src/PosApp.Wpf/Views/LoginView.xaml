<Window x:Class="PosApp.Wpf.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Login_Title}"
        Width="520" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Top" Height="200">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="80" Height="80" Background="White" CornerRadius="40" Margin="0,0,0,12">
                    <TextBlock Text="P" FontSize="48" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource App_Title}" FontSize="28" FontWeight="SemiBold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource App_Tagline}" FontSize="13"
                           Foreground="#DBEAFE" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Margin="40,140,40,40"
                Padding="32" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="{DynamicResource Login_Title}" Style="{StaticResource Heading2}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{DynamicResource Login_Username}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,12" FontSize="15"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{DynamicResource Login_Password}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PinBox" Margin="0,0,0,8" FontSize="15"
                             KeyDown="PinBox_KeyDown"/>

                <TextBlock x:Name="ErrorText" Text="{Binding Error}"
                           Foreground="{StaticResource DangerBrush}" FontSize="12"
                           Margin="0,4,0,8" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="{DynamicResource Login_Button}" Style="{StaticResource PrimaryButton}"
                        Margin="0,12,0,8" Padding="0,14" FontSize="15"
                        Click="LoginButton_Click"/>

                <Button Content="{DynamicResource Login_Exit}" Style="{StaticResource OutlineButton}"
                        Margin="0,4,0,0" Padding="0,10"
                        Click="Exit_Click"/>

                <Border Background="#F1F5F9" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Demo accounts" Style="{StaticResource Muted}" FontWeight="SemiBold"/>
                        <TextBlock Text="admin / 1234  -  full access" Style="{StaticResource Muted}" Margin="0,4,0,0"/>
                        <TextBlock Text="cashier / 1111  -  POS only" Style="{StaticResource Muted}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" Text="© 2026 PosApp - Local Point of Sale"
                   Style="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
    </Grid>
</Window>
