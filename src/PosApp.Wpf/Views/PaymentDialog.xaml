<Window x:Class="PosApp.Wpf.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Pay_Title}"
        Width="760" Height="690"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Sale total and amount still unpaid -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="8"
                Padding="20,14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{DynamicResource Pay_AmountDue}" Foreground="#DBEAFE" FontSize="12"/>
                    <TextBlock x:Name="AmountDueText" FontSize="30" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{DynamicResource Pay_Remaining}" Foreground="#DBEAFE" FontSize="12"
                               HorizontalAlignment="Right"/>
                    <TextBlock x:Name="RemainingText" FontSize="30" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Payment methods. Cash is the default and the only method that allows change. -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="MethodCash" Style="{StaticResource PrimaryButton}"
                    Content="{DynamicResource Pay_Cash}" Margin="0,0,4,0" Padding="10,9"
                    Click="Method_Click" Tag="0"/>
            <Button Grid.Column="1" x:Name="MethodCard" Style="{StaticResource OutlineButton}"
                    Content="{DynamicResource Pay_Card}" Margin="4,0" Padding="10,9"
                    Click="Method_Click" Tag="1"/>
            <Button Grid.Column="2" x:Name="MethodMobile" Style="{StaticResource OutlineButton}"
                    Content="{DynamicResource Pay_Mobile}" Margin="4,0" Padding="10,9"
                    Click="Method_Click" Tag="2"/>
            <Button Grid.Column="3" x:Name="MethodBank" Style="{StaticResource OutlineButton}"
                    Content="{DynamicResource Pay_Bank}" Margin="4,0,0,0" Padding="10,9"
                    Click="Method_Click" Tag="3"/>
        </Grid>

        <!-- Paid amount and live change preview -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Pay_Tendered}" Style="{StaticResource Muted}"/>
                    <TextBox x:Name="TenderedBox" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"
                             TextChanged="TenderedBox_TextChanged"
                             PreviewTextInput="TenderedBox_PreviewTextInput"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0" Padding="14"
                    Background="{DynamicResource SuccessSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Pay_Change}" Foreground="{DynamicResource SuccessTextBrush}" FontSize="12"/>
                    <TextBlock x:Name="ChangeText" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessTextBrush}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Touch keypad and split-payment ledger -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource PadButton}" Content="7" Click="Pad_Click" Tag="7"/>
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource PadButton}" Content="8" Click="Pad_Click" Tag="8"/>
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource PadButton}" Content="9" Click="Pad_Click" Tag="9"/>
                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource PadButton}" Content="4" Click="Pad_Click" Tag="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource PadButton}" Content="5" Click="Pad_Click" Tag="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource PadButton}" Content="6" Click="Pad_Click" Tag="6"/>
                        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource PadButton}" Content="1" Click="Pad_Click" Tag="1"/>
                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource PadButton}" Content="2" Click="Pad_Click" Tag="2"/>
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource PadButton}" Content="3" Click="Pad_Click" Tag="3"/>
                        <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource PadButton}" Content="0" Click="Pad_Click" Tag="0"/>
                        <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource PadButton}" Content="." Click="Pad_Click" Tag="."/>
                        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource PadButton}"
                                Content="{DynamicResource Pay_Backspace}" Click="Pad_Click" Tag="back" FontSize="13"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="QuickExact" Style="{StaticResource OutlineButton}"
                                Content="{DynamicResource Pay_Exact}" Click="QuickCash_Click" Margin="2" Padding="4,7"/>
                        <Button Grid.Column="1" x:Name="QuickOne" Style="{StaticResource OutlineButton}"
                                Click="QuickCash_Click" Margin="2" Padding="4,7"/>
                        <Button Grid.Column="2" x:Name="QuickTwo" Style="{StaticResource OutlineButton}"
                                Click="QuickCash_Click" Margin="2" Padding="4,7"/>
                        <Button Grid.Column="3" x:Name="QuickThree" Style="{StaticResource OutlineButton}"
                                Click="QuickCash_Click" Margin="2" Padding="4,7"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{DynamicResource Pay_Payments}" Style="{StaticResource Heading3}"
                               Margin="0,0,0,8"/>
                    <ListBox Grid.Row="1" x:Name="PaymentsList" BorderThickness="0"
                             Background="Transparent" Foreground="{DynamicResource TextDarkBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding MethodName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{DynamicResource Pay_Remove}"
                                            Style="{StaticResource OutlineButton}" Padding="6,3" Margin="6,0,0,0"
                                            Click="RemovePayment_Click" Tag="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Pay_Received}" Style="{StaticResource Muted}"/>
                        <TextBlock x:Name="ReceivedText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Add a partial tender, or complete once the remaining balance reaches zero. -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{DynamicResource Pay_Cancel}" Style="{StaticResource OutlineButton}"
                    Margin="0,0,4,0" Padding="0,12" Click="Cancel_Click"/>
            <Button Grid.Column="1" Content="{DynamicResource Pay_AddPayment}" Style="{StaticResource OutlineButton}"
                    Margin="4" Padding="0,12" Click="AddPayment_Click"/>
            <Button Grid.Column="2" x:Name="CompleteButton" Content="{DynamicResource Pay_Complete}"
                    Style="{StaticResource SuccessButton}" Margin="4,0,0,0" Padding="0,12"
                    FontSize="15" Click="Complete_Click"/>
        </Grid>
    </Grid>
</Window>
