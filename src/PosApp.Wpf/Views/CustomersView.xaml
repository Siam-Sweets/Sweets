<UserControl x:Class="PosApp.Wpf.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Cust_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Cust_Subtitle}" Style="{StaticResource Muted}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource Cust_Add}" Style="{StaticResource PrimaryButton}"
                    Click="Add_Click" Padding="20,12"/>
        </Grid>

        <TextBox Grid.Row="1" x:Name="SearchBox" TextChanged="Search_TextChanged"
                 Padding="12,10" Margin="0,0,0,12" FontSize="14"/>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="CustomersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Cust_Name}" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource Cust_Phone}" Binding="{Binding Phone}" Width="160"/>
                    <DataGridTextColumn Header="{DynamicResource Cust_Email}" Binding="{Binding Email}" Width="220"/>
                    <DataGridTemplateColumn Header="{DynamicResource Common_Actions}" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource Cust_History}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="History_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource Prod_Edit}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Edit_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource Common_Delete}" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Margin="2" Click="Delete_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
