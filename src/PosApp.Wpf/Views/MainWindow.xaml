<Window x:Class="PosApp.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PosApp" Width="1366" Height="800"
        Icon="/PosApp;component/Assets/PosApp.ico"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource BackgroundBrush}"
        Loaded="MainWindow_Loaded">
    <Window.Resources>
        <!-- The global TextBlock style supplies page text colors. Sidebar labels
             must instead follow their parent button so they stay readable in
             both Light and Dark themes and when the button becomes active. -->
        <Style x:Key="SidebarNavText" TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground"
                    Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,16">
                    <Image Width="40" Height="40" Stretch="Uniform"
                           Source="/PosApp;component/Assets/PosAppLogo.png"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PosApp" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="POS System" FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="12,8">
                    <Button x:Name="NavPos" Style="{StaticResource NavButtonActive}" Click="Nav_Click" Tag="pos">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="🛒" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_POS}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavRegister" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="register">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="💵" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Register}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavProducts" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="products">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="📦" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Products}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavInventory" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="inventory">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="📊" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Inventory}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavPurchases" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="purchases">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="🚚" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Purchases}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavCustomers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="customers">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="👥" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Customers}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSales" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="sales">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="🧾" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Sales}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavReports" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="reports">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="📈" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Reports}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavUsers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="users">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="🔐" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Users}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="⚙️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User card + logout -->
                <Border Grid.Row="2" Background="#0F172A" Margin="12" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{StaticResource PrimaryBrush}" CornerRadius="18">
                            <TextBlock x:Name="UserInitials" Text="A" Foreground="White" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="UserName" Text="Admin" Foreground="White" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="UserRoleLabel" Text="Admin" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="2" Width="32" Height="32" Padding="5"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="Logout_Click" ToolTip="{DynamicResource Nav_Logout}">
                            <!-- Vector icon avoids the missing-font square shown by the old glyph. -->
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10,4 L5,4 L5,20 L10,20"
                                          Stroke="#CBD5E1" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Path Data="M13,8 L17,12 L13,16 M17,12 L9,12"
                                          Stroke="#CBD5E1" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="ContentArea"/>
        </Grid>
    </Grid>
</Window>
