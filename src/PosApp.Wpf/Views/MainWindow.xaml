<Window x:Class="PosApp.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PosApp" Width="1366" Height="800"
        Icon="/PosApp;component/Assets/PosApp.ico"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{DynamicResource BackgroundBrush}" Loaded="MainWindow_Loaded">
    <Window.Resources>
        <Style x:Key="SidebarNavText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
        </Style>
        <Style x:Key="DrawerAction" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ActionBorder" Property="Background" Value="{DynamicResource DrawerHoverBrush}"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid x:Name="ShellGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Management navigation is hidden while serving customers. -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" x:Name="NavPos" Tag="pos" Click="Nav_Click" Background="Transparent" BorderThickness="0"
                            HorizontalContentAlignment="Left" Padding="18,20" Cursor="Hand">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Image Width="36" Height="36" Source="/PosApp;component/Assets/PosAppLogo.png"/>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="PosApp" Foreground="{DynamicResource SidebarTextBrush}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{DynamicResource Shell_BackToPOS}" Foreground="{DynamicResource InfoTextBrush}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="10,6">
                            <TextBlock Text="{DynamicResource Shell_Management}" Foreground="{DynamicResource SidebarMutedBrush}" FontSize="11" FontWeight="Bold" Margin="10,4,10,8"/>
                            <Button x:Name="NavDashboard" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="dashboard"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_Dashboard}"/></Button>
                            <Button x:Name="NavSales" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="sales"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_Documents}"/></Button>
                            <Button x:Name="NavProducts" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="products"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Products}"/></Button>
                            <Button x:Name="NavInventory" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="inventory"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_Stock}"/></Button>
                            <Button x:Name="NavPurchases" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="purchases"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Purchases}"/></Button>
                            <Button x:Name="NavRegister" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="register"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Register}"/></Button>
                            <Button x:Name="NavCustomers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="customers"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_CustomersSuppliers}"/></Button>
                            <Button x:Name="NavReports" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="reports"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_Reporting}"/></Button>
                            <Button x:Name="NavPromotions" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="promotions"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_Promotions}"/></Button>
                            <Button x:Name="NavUsers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="users"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Shell_UsersSecurity}"/></Button>
                            <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="settings"><TextBlock Style="{StaticResource SidebarNavText}" Text="{DynamicResource Nav_Settings}"/></Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{DynamicResource SidebarCardBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" Margin="10" CornerRadius="7" Padding="11">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="{StaticResource PrimaryBrush}" CornerRadius="18">
                                <TextBlock x:Name="UserInitials" Text="A" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="UserName" Text="Administrator" Foreground="{DynamicResource SidebarTextBrush}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="UserRoleLabel" Text="Admin" Foreground="{DynamicResource SidebarMutedBrush}" FontSize="11"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Exit" Foreground="{DynamicResource SidebarTextBrush}" Background="Transparent" BorderThickness="0" Click="Logout_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1"><ContentControl x:Name="ContentArea"/></Grid>
        </Grid>

        <!-- Slide-over used from the receipt screen. -->
        <Grid x:Name="ManagementOverlay" Visibility="Collapsed" Panel.ZIndex="50">
            <Border Background="{DynamicResource OverlayScrimBrush}" MouseLeftButtonDown="DrawerBackground_MouseLeftButtonDown"/>
            <Border Width="410" HorizontalAlignment="Right" Background="{DynamicResource DrawerPanelBrush}" BorderBrush="{DynamicResource DrawerBorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="20,18,14,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="DrawerTitle" Foreground="{DynamicResource DrawerTextBrush}" FontSize="22" FontWeight="SemiBold"/>
                            <TextBlock Text="{DynamicResource Shell_OfflineTerminal}" Foreground="{DynamicResource DrawerMutedBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Style="{StaticResource DrawerAction}" Padding="12,8" Click="CloseManagementDrawer_Click"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,0">
                            <Button x:Name="DrawerManagement" Style="{StaticResource DrawerAction}" Tag="dashboard" Click="ManagementAction_Click" Content="{DynamicResource Shell_Management}"/>
                            <Button x:Name="DrawerSales" Style="{StaticResource DrawerAction}" Tag="sales" Click="ManagementAction_Click" Content="{DynamicResource Shell_ViewSales}"/>
                            <Button x:Name="DrawerOpenSales" Style="{StaticResource DrawerAction}" Tag="pos" Click="OpenSales_Click" Content="{DynamicResource Shell_OpenSales}"/>
                            <Button x:Name="DrawerRegister" Style="{StaticResource DrawerAction}" Tag="register" Click="ManagementAction_Click" Content="{DynamicResource Shell_CashInOut}"/>
                            <Button x:Name="DrawerReports" Style="{StaticResource DrawerAction}" Tag="register" Click="ManagementAction_Click" Content="{DynamicResource Shell_EndOfDay}"/>
                            <Border Height="1" Background="{DynamicResource DrawerBorderBrush}" Margin="14,8"/>
                            <TextBlock Text="{DynamicResource Shell_User}" Foreground="{DynamicResource DrawerMutedBrush}" Margin="18,8,18,4" FontSize="12" FontWeight="Bold"/>
                            <Button Style="{StaticResource DrawerAction}" Click="UserInfo_Click" Content="{DynamicResource Shell_UserInfo}"/>
                            <Button Style="{StaticResource DrawerAction}" Click="DrawerSignOut_Click" Content="{DynamicResource Shell_SignOut}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" x:Name="DrawerDate" Foreground="{DynamicResource DrawerMutedBrush}" HorizontalAlignment="Center" FontSize="17" Margin="0,16"/>

                    <UniformGrid Grid.Row="3" Columns="3" Margin="10,0,10,12">
                        <Button x:Name="DrawerSettings" Content="{DynamicResource Nav_Settings}" Style="{StaticResource DrawerAction}" HorizontalContentAlignment="Center" Click="DrawerSettings_Click"/>
                        <Button Content="{DynamicResource Shell_FullScreen}" Style="{StaticResource DrawerAction}" HorizontalContentAlignment="Center" Click="DrawerFullscreen_Click"/>
                        <Button Content="{DynamicResource Shell_ExitApp}" Style="{StaticResource DrawerAction}" HorizontalContentAlignment="Center" Click="DrawerExit_Click"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
