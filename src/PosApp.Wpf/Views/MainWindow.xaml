<Window x:Class="PosApp.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PosApp" Width="1366" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}"
        Loaded="MainWindow_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,16">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryBrush}" CornerRadius="8">
                        <TextBlock Text="P" FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PosApp" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="POS System" FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="12,8">
                    <Button x:Name="NavPos" Style="{StaticResource NavButtonActive}" Click="Nav_Click" Tag="pos">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛒" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_POS}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavProducts" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="products">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Products}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavInventory" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="inventory">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Inventory}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavCustomers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="customers">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Customers}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSales" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="sales">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧾" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Sales}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavReports" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="reports">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Reports}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavUsers" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="users">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔐" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Users}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings" Style="{StaticResource NavButton}" Click="Nav_Click" Tag="settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Nav_Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User card + logout -->
                <Border Grid.Row="2" Background="#0F172A" Margin="12" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36" Background="{StaticResource PrimaryBrush}" CornerRadius="18">
                            <TextBlock x:Name="UserInitials" Text="A" Foreground="White" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="UserName" Text="Admin" Foreground="White" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="UserRoleLabel" Text="Admin" Foreground="#94A3B8" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Click="Logout_Click" ToolTip="Logout">
                            <TextBlock Text="⏻" Foreground="#94A3B8" FontSize="18"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="ContentArea"/>
        </Grid>
    </Grid>
</Window>
