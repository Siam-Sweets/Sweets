<UserControl x:Class="PosApp.Wpf.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Reg_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Reg_Subtitle}"
                           Style="{StaticResource Muted}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{DynamicResource Common_Print}" Style="{StaticResource OutlineButton}"
                        Click="PrintPage_Click" Padding="18,9" Margin="0,0,8,0"/>
                <Border x:Name="StatusBorder" CornerRadius="16" Padding="14,7"
                        Background="{DynamicResource SurfaceMutedBrush}" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="{DynamicResource Reg_NoOpen}" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Reg_OpeningCash}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="OpeningText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Reg_CashSales}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="CashSalesText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Reg_CashInOut}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="MovementsText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0"
                    Background="{DynamicResource InfoSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Reg_ExpectedDrawer}" Style="{StaticResource Muted}"
                               Foreground="{DynamicResource InfoTextBrush}"/>
                    <TextBlock x:Name="ExpectedText" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource InfoTextBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="OpenButton" Content="{DynamicResource Reg_Open}" Style="{StaticResource SuccessButton}"
                    Click="Open_Click" Margin="0,0,8,0"/>
            <Button x:Name="CashInButton" Content="{DynamicResource Reg_CashIn}" Style="{StaticResource OutlineButton}"
                    Click="CashIn_Click" Margin="0,0,8,0"/>
            <Button x:Name="CashOutButton" Content="{DynamicResource Reg_CashOut}" Style="{StaticResource OutlineButton}"
                    Click="CashOut_Click" Margin="0,0,8,0"/>
            <Button x:Name="ReportButton" Content="{DynamicResource Reg_XReport}" Style="{StaticResource OutlineButton}"
                    Click="Report_Click" Margin="0,0,8,0"/>
            <Button x:Name="CloseButton" Content="{DynamicResource Reg_CloseZ}" Style="{StaticResource DangerButton}"
                    Click="Close_Click"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock Text="{DynamicResource Reg_CurrentMovements}" DockPanel.Dock="Top"
                               FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="MovementGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Reg_Time}" Binding="{Binding LocalTime, StringFormat='{}{0:dd MMM HH:mm}'}" Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Inv_Type}" Binding="{Binding Type}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource Reg_Reason}" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource Reg_Amount}" Binding="{Binding SignedAmount, Converter={StaticResource Money}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock Text="{DynamicResource Reg_RecentSessions}" DockPanel.Dock="Top"
                               FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="SessionGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="SessionGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Reg_Opened}" Binding="{Binding OpenedLocal, StringFormat='{}{0:dd MMM HH:mm}'}" Width="125"/>
                            <DataGridTextColumn Header="{DynamicResource Reg_Closed}" Binding="{Binding ClosedLocal, StringFormat='{}{0:dd MMM HH:mm}'}" Width="125"/>
                            <DataGridTextColumn Header="{DynamicResource Sales_Status}" Binding="{Binding Status}" Width="85"/>
                            <DataGridTextColumn Header="{DynamicResource Reg_Expected}" Binding="{Binding Expected, Converter={StaticResource Money}}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Reg_Variance}" Binding="{Binding Variance, Converter={StaticResource Money}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
