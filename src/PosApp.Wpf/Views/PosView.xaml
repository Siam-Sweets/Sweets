<UserControl x:Class="PosApp.Wpf.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="PosView_PreviewKeyDown">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
        <Style x:Key="CommandTile" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CommandTileBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CommandTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CommandBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource CommandTileHoverBrush}"/>
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaymentTile" TargetType="Button" BasedOn="{StaticResource CommandTile}">
            <Setter Property="Background" Value="{DynamicResource SuccessSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SuccessTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
        </Style>

        <Style x:Key="DangerTile" TargetType="Button" BasedOn="{StaticResource CommandTile}">
            <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style x:Key="CommandCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ShortcutLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource InfoTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ProductResultButton" TargetType="Button">
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="104"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResultBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchFilterChip" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="FilterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="FilterBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="FilterBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FilterBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="620"/>
            <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <!-- Receipt workspace -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="132"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="BarcodeBox" FontSize="18" Padding="14,10"
                                 CaretBrush="{DynamicResource TextDarkBrush}"
                                 VerticalContentAlignment="Center"
                                 KeyDown="BarcodeBox_KeyDown"
                                 TextChanged="BarcodeBox_TextChanged"/>
                        <TextBlock x:Name="BarcodePlaceholder"
                                   Text="{DynamicResource POS_SearchReceipt}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="17" Margin="16,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=BarcodeBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=BarcodeBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="1" Content="{DynamicResource POS_SearchButton}"
                            Style="{StaticResource PrimaryButton}" Padding="22,11"
                            Margin="10,0,0,0" Click="SearchProducts_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <DataGrid x:Name="ReceiptGrid" ItemsSource="{Binding CartLines}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          RowHeight="52" FontSize="14" BorderThickness="0"
                          Background="{DynamicResource BackgroundBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource POS_ProductName}"
                                            Binding="{Binding ProductName, Mode=OneWay}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource POS_Quantity}"
                                            Binding="{Binding QuantityDisplay, Mode=OneWay}" Width="120"/>
                        <DataGridTemplateColumn Header="{DynamicResource POS_Price}" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="{Binding UnitPrice, Mode=OneWay, Converter={StaticResource Money}}"/><Run Text=" / "/><Run Text="{Binding UnitSymbol, Mode=OneWay}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource POS_Amount}"
                                            Binding="{Binding LineTotal, Mode=OneWay, Converter={StaticResource Money}}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCartEmpty, Mode=OneWay}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{DynamicResource POS_NoItems}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource POS_NoItemsHint}" FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SaleContextDisplay, Mode=OneWay}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding NoteDisplay, Mode=OneWay}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource POS_Subtotal}"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Subtotal, Mode=OneWay, Converter={StaticResource Money}}"
                                   Foreground="{DynamicResource TextDarkBrush}" Margin="20,2,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource POS_TaxDiscount}"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="20,2,0,2"
                                   Foreground="{DynamicResource TextDarkBrush}">
                            <Run Text="{Binding TaxTotal, Mode=OneWay, Converter={StaticResource Money}}"/><Run Text=" / -"/><Run Text="{Binding DiscountTotal, Mode=OneWay, Converter={StaticResource Money}}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource POS_Total}"
                                   FontSize="21" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Total, Mode=OneWay, Converter={StaticResource Money}}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="20,8,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Fast command rail -->
        <Border Grid.Column="1" Background="{DynamicResource CommandPanelBrush}"
                BorderBrush="{DynamicResource CommandBorderBrush}" BorderThickness="1,0,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="108"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="174"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,8,8,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource POS_Receipt}" Foreground="{DynamicResource CommandTextBrush}"
                                   FontSize="23" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CustomerDisplay, Mode=OneWay}" Foreground="{DynamicResource CommandMutedBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="1" Columns="2">
                    <Button Style="{StaticResource CommandTile}" Click="DeleteLine_Click">
                        <Grid>
                            <TextBlock Text="Del" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource Common_Delete}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Quantity_Click">
                        <Grid>
                            <TextBlock Text="F4" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource POS_Quantity}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                </UniformGrid>


                <UniformGrid Grid.Row="2" Columns="3" Rows="3">
                    <Button Style="{StaticResource CommandTile}" Click="ServiceType_Click"><TextBlock Text="{DynamicResource POS_ServiceType}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Discount_Click">
                        <Grid>
                            <TextBlock Text="F2" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource POS_Discount}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Comment_Click"><TextBlock Text="{DynamicResource POS_Comment}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="CustomerButton_Click"><TextBlock Text="{DynamicResource POS_Customer}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Suspend_Click">
                        <Grid>
                            <TextBlock Text="F9" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource POS_SaveSale}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Refund_Click"><TextBlock Text="{DynamicResource POS_CustomRefund}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource PaymentTile}" Click="Checkout_Click">
                        <Grid>
                            <TextBlock Text="F10" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource POS_Payment}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Recall_Click">
                        <Grid>
                            <TextBlock Text="F7" Style="{StaticResource ShortcutLabel}" VerticalAlignment="Top"/>
                            <TextBlock Text="{DynamicResource POS_Transfer}" Style="{StaticResource CommandCaption}"/>
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Management_Click"><TextBlock Text="{DynamicResource POS_More}" Style="{StaticResource CommandCaption}"/></Button>
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="68"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="3" Background="{DynamicResource CommandStatusBrush}"
                            BorderBrush="{DynamicResource CommandBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ServiceTypeDisplay, Mode=OneWay}" Foreground="{DynamicResource CommandTextBrush}" FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock Text="{Binding ActiveSaleDisplay, Mode=OneWay}" Foreground="{DynamicResource CommandMutedBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Row="1" Style="{StaticResource DangerTile}" Click="VoidOrder_Click">
                        <TextBlock Text="{DynamicResource POS_VoidOrder}" Style="{StaticResource CommandCaption}" FontSize="15"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Responsive product-search overlay; cards recalculate from the available viewport. -->
        <Grid x:Name="SearchOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Panel.ZIndex="20">
            <Border Background="{DynamicResource OverlayScrimBrush}" MouseLeftButtonDown="SearchScrim_MouseLeftButtonDown"/>
            <Border x:Name="ProductSearchPanel" Margin="24" MaxWidth="1100" MaxHeight="760"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource POS_FindProducts}" Style="{StaticResource Heading2}"/>
                            <TextBlock Text="{DynamicResource POS_FindProductsHint}" Style="{StaticResource Muted}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{DynamicResource Common_Close}" Style="{StaticResource OutlineButton}"
                                Padding="18,9" Click="CloseSearch_Click"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource POS_SearchField}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <UniformGrid Grid.Column="1" Columns="4">
                            <RadioButton x:Name="SearchAllFilter" GroupName="ProductSearchField" Tag="All"
                                         Content="{DynamicResource POS_SearchAllFields}" IsChecked="True"
                                         Style="{StaticResource SearchFilterChip}" Checked="SearchField_Checked"/>
                            <RadioButton GroupName="ProductSearchField" Tag="Name"
                                         Content="{DynamicResource POS_SearchProductName}"
                                         Style="{StaticResource SearchFilterChip}" Checked="SearchField_Checked"/>
                            <RadioButton GroupName="ProductSearchField" Tag="Code"
                                         Content="{DynamicResource POS_SearchProductCode}"
                                         Style="{StaticResource SearchFilterChip}" Checked="SearchField_Checked"/>
                            <RadioButton GroupName="ProductSearchField" Tag="Barcode"
                                         Content="{DynamicResource POS_SearchBarcode}"
                                         Style="{StaticResource SearchFilterChip}" Checked="SearchField_Checked"/>
                        </UniformGrid>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <TextBox x:Name="ProductSearchBox" Padding="14,11"
                                 FontSize="17" TextChanged="ProductSearchBox_TextChanged"
                                 KeyDown="ProductSearchBox_KeyDown"/>
                        <TextBlock Text="{DynamicResource POS_SearchFilterHint}"
                                   Margin="16,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="15"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=ProductSearchBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=ProductSearchBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ScrollViewer x:Name="ProductResultsScrollViewer" Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  SizeChanged="ProductResultsScrollViewer_SizeChanged">
                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ProductResultButton}" Tag="{Binding}" Click="Product_Click"
                                            MinWidth="180" MinHeight="170"
                                            Width="{Binding DataContext.ProductCardWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            Height="{Binding DataContext.ProductCardHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="42"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding Name}" ToolTip="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="13" LineHeight="18"
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Grid.Row="1" Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Sku}">
                                                <Run Text="{DynamicResource POS_CodeLabel}"/><Run Text=": "/><Run Text="{Binding Sku, Mode=OneWay}"/>
                                            </TextBlock>

                                            <TextBlock Grid.Row="2" Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Barcode}">
                                                <Run Text="{DynamicResource POS_BarcodeLabel}"/><Run Text=": "/><Run Text="{Binding Barcode, Mode=OneWay}"/>
                                            </TextBlock>

                                            <Border Grid.Row="4" Margin="0,10,0,0" Padding="0,8,0,0"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Foreground="{DynamicResource PrimaryBrush}"
                                                               FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Price, Mode=OneWay, Converter={StaticResource Money}}"/><Run Text=" / "/><Run Text="{Binding UnitSymbol, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Row="1" Foreground="{DynamicResource TextMutedBrush}"
                                                               FontSize="11" Margin="0,3,0,0" TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding StockQuantity, Mode=OneWay, StringFormat='Stock {0:0.###}'}"/><Run Text=" "/><Run Text="{Binding UnitSymbol, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <ItemsControl Grid.Row="4" ItemsSource="{Binding VirtualKeys}" Margin="0,8,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding VirtualKeyboardVisible}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><Button Content="{Binding}" Tag="{Binding}" Click="VirtualKey_Click" Style="{StaticResource OutlineButton}" MinWidth="38" Padding="8,5" Margin="2"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl Grid.Row="5" ItemsSource="{Binding Categories}" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" Tag="{Binding Id}" Click="Category_Click"
                                        Style="{StaticResource OutlineButton}" Padding="13,7" Margin="0,0,7,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
