<UserControl x:Class="PosApp.Wpf.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}"
             PreviewKeyDown="PosView_PreviewKeyDown">
    <UserControl.Resources>
        <Style x:Key="CommandTile" TargetType="Button">
            <Setter Property="Background" Value="#243247"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#334155"/>
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaymentTile" TargetType="Button" BasedOn="{StaticResource CommandTile}">
            <Setter Property="Background" Value="#166534"/>
            <Setter Property="BorderBrush" Value="#22C55E"/>
        </Style>

        <Style x:Key="DangerTile" TargetType="Button" BasedOn="{StaticResource CommandTile}">
            <Setter Property="Background" Value="#991B1B"/>
            <Setter Property="BorderBrush" Value="#F87171"/>
        </Style>

        <Style x:Key="CommandCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ShortcutLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#93C5FD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ProductResultButton" TargetType="Button">
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="104"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResultBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResultBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="ResultBorder" Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="620"/>
            <ColumnDefinition Width="430"/>
        </Grid.ColumnDefinitions>

        <!-- Receipt workspace -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="132"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="BarcodeBox" FontSize="18" Padding="14,10"
                                 VerticalContentAlignment="Center"
                                 KeyDown="BarcodeBox_KeyDown"
                                 TextChanged="BarcodeBox_TextChanged"/>
                        <TextBlock x:Name="BarcodePlaceholder"
                                   Text="{DynamicResource POS_SearchReceipt}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   FontSize="17" Margin="16,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"/>
                    </Grid>
                    <Button Grid.Column="1" Content="{DynamicResource POS_SearchButton}"
                            Style="{StaticResource PrimaryButton}" Padding="22,11"
                            Margin="10,0,0,0" Click="SearchProducts_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <DataGrid x:Name="ReceiptGrid" ItemsSource="{Binding CartLines}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          RowHeight="52" FontSize="14" BorderThickness="0"
                          Background="{DynamicResource BackgroundBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource POS_ProductName}"
                                            Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource POS_Quantity}"
                                            Binding="{Binding Quantity, StringFormat=0.###}" Width="120"/>
                        <DataGridTextColumn Header="{DynamicResource POS_Price}"
                                            Binding="{Binding UnitPrice, StringFormat={}{0:0.00}}" Width="135"/>
                        <DataGridTextColumn Header="{DynamicResource POS_Amount}"
                                            Binding="{Binding LineTotal, StringFormat={}{0:0.00}}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCartEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{DynamicResource POS_NoItems}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextDarkBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource POS_NoItemsHint}" FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SaleContextDisplay}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextDarkBrush}"/>
                        <TextBlock Text="{Binding NoteDisplay}" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource POS_Subtotal}"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Subtotal, StringFormat={}{0:0.00}}"
                                   Foreground="{DynamicResource TextDarkBrush}" Margin="20,2,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource POS_TaxDiscount}"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="20,2,0,2"
                                   Foreground="{DynamicResource TextDarkBrush}">
                            <Run Text="{Binding TaxTotal, StringFormat={}{0:0.00}}"/><Run Text=" / -"/><Run Text="{Binding DiscountTotal, StringFormat={}{0:0.00}}"/>
                        </TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource POS_Total}"
                                   FontSize="21" FontWeight="Bold" Foreground="{DynamicResource TextDarkBrush}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Total, StringFormat={}{0:0.00}}"
                                   FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="20,8,0,0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Fast command rail -->
        <Border Grid.Column="1" Background="#182235" BorderBrush="#334155" BorderThickness="1,0,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="108"/>
                    <RowDefinition Height="68"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="174"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="8,8,8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource POS_Receipt}" Foreground="White"
                                   FontSize="23" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CustomerDisplay}" Foreground="#CBD5E1" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource POS_Menu}" Style="{StaticResource CommandTile}"
                            Width="76" Height="48" Click="Management_Click"/>
                </Grid>

                <UniformGrid Grid.Row="1" Columns="4">
                    <Button Style="{StaticResource CommandTile}" Click="DeleteLine_Click">
                        <StackPanel><TextBlock Text="Del" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource Common_Delete}" Style="{StaticResource CommandCaption}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="SearchProducts_Click">
                        <StackPanel><TextBlock Text="F3" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource Common_Search}" Style="{StaticResource CommandCaption}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Quantity_Click">
                        <StackPanel><TextBlock Text="F4" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_Quantity}" Style="{StaticResource CommandCaption}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="NewSale_Click">
                        <StackPanel><TextBlock Text="F8" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_NewSale}" Style="{StaticResource CommandCaption}"/></StackPanel>
                    </Button>
                </UniformGrid>

                <UniformGrid Grid.Row="2" Columns="3">
                    <Button Style="{StaticResource PaymentTile}" Click="QuickCash_Click">
                        <StackPanel><TextBlock Text="F12" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource Pay_Cash}" Style="{StaticResource CommandCaption}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Card_Click">
                        <TextBlock Text="{DynamicResource Pay_Card}" Style="{StaticResource CommandCaption}"/>
                    </Button>
                    <Button Style="{StaticResource CommandTile}" Click="Check_Click">
                        <TextBlock Text="{DynamicResource POS_Check}" Style="{StaticResource CommandCaption}"/>
                    </Button>
                </UniformGrid>

                <UniformGrid Grid.Row="3" Columns="4" Rows="3">
                    <Button Style="{StaticResource CommandTile}" Click="CashDrawer_Click"><TextBlock Text="{DynamicResource POS_CashDrawer}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="ServiceType_Click"><TextBlock Text="{DynamicResource POS_ServiceType}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Discount_Click"><StackPanel><TextBlock Text="F2" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_Discount}" Style="{StaticResource CommandCaption}"/></StackPanel></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Comment_Click"><TextBlock Text="{DynamicResource POS_Comment}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="CustomerButton_Click"><TextBlock Text="{DynamicResource POS_Customer}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Weigh_Click"><TextBlock Text="{DynamicResource POS_Weigh}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Suspend_Click"><StackPanel><TextBlock Text="F9" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_SaveSale}" Style="{StaticResource CommandCaption}"/></StackPanel></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Refund_Click"><TextBlock Text="{DynamicResource Sales_Refund}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource PaymentTile}" Click="Checkout_Click"><StackPanel><TextBlock Text="F10" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_Payment}" Style="{StaticResource CommandCaption}"/></StackPanel></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Lock_Click"><TextBlock Text="{DynamicResource POS_Lock}" Style="{StaticResource CommandCaption}"/></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Recall_Click"><StackPanel><TextBlock Text="F7" Style="{StaticResource ShortcutLabel}"/><TextBlock Text="{DynamicResource POS_Transfer}" Style="{StaticResource CommandCaption}"/></StackPanel></Button>
                    <Button Style="{StaticResource CommandTile}" Click="Management_Click"><TextBlock Text="{DynamicResource POS_More}" Style="{StaticResource CommandCaption}"/></Button>
                </UniformGrid>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="68"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="3" Background="#111827" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding ServiceTypeDisplay}" Foreground="White" FontWeight="SemiBold" FontSize="15"/>
                            <TextBlock Text="{Binding ActiveSaleDisplay}" Foreground="#94A3B8" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Button Grid.Row="1" Style="{StaticResource DangerTile}" Click="VoidOrder_Click">
                        <TextBlock Text="{DynamicResource POS_VoidOrder}" Style="{StaticResource CommandCaption}" FontSize="15"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Product search panel. It is an overlay so result cards keep a stable size. -->
        <Grid x:Name="SearchOverlay" Grid.ColumnSpan="2" Visibility="Collapsed" Panel.ZIndex="20">
            <Border Background="#B30F172A" MouseLeftButtonDown="SearchScrim_MouseLeftButtonDown"/>
            <Border Width="940" Height="650" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource PrimaryBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource POS_FindProducts}" Style="{StaticResource Heading2}"/>
                            <TextBlock Text="{DynamicResource POS_FindProductsHint}" Style="{StaticResource Muted}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="{DynamicResource Common_Close}" Style="{StaticResource OutlineButton}"
                                Padding="18,9" Click="CloseSearch_Click"/>
                    </Grid>
                    <TextBox x:Name="ProductSearchBox" Grid.Row="1" Margin="0,16,0,10" Padding="14,11"
                             FontSize="17" TextChanged="ProductSearchBox_TextChanged"
                             KeyDown="ProductSearchBox_KeyDown"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Products}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ProductResultButton}" Tag="{Binding}" Click="Product_Click"
                                            Width="{Binding DataContext.ProductCardWidth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                            Height="{Binding DataContext.ProductCardHeight, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="42"/>
                                                <TextBlock Text="{Binding Sku}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Price, StringFormat={}{0:0.00}}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding StockQuantity, StringFormat='Stock {0:0.###}'}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                                            </Grid>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <ItemsControl Grid.Row="3" ItemsSource="{Binding VirtualKeys}" Margin="0,8,0,0">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding VirtualKeyboardVisible}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate><Button Content="{Binding}" Tag="{Binding}" Click="VirtualKey_Click" Style="{StaticResource OutlineButton}" MinWidth="38" Padding="8,5" Margin="2"/></DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl Grid.Row="4" ItemsSource="{Binding Categories}" Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" Tag="{Binding Id}" Click="Category_Click"
                                        Style="{StaticResource OutlineButton}" Padding="13,7" Margin="0,0,7,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
