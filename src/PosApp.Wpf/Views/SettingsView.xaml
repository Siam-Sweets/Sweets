<UserControl x:Class="PosApp.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource Set_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Configure store, hardware, language, and appearance" Style="{StaticResource Muted}"/>
            </StackPanel>

            <!-- Store info -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Set_Store}" Style="{StaticResource Heading3}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="{DynamicResource Set_StoreName}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="StoreNameBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="{DynamicResource Set_Phone}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="PhoneBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="{DynamicResource Set_Email}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="EmailBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="{DynamicResource Set_TaxId}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TaxIdBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Set_Address}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="AddressBox" Padding="10,8" AcceptsReturn="True" Height="60" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="{DynamicResource Set_Currency}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="CurrencyBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="{DynamicResource Set_Footer}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FooterBox" Padding="10,8"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Hardware -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Set_Hardware}" Style="{StaticResource Heading3}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="{DynamicResource Set_Printer}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="PrinterCombo" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                            <TextBlock Text="{DynamicResource Set_DrawerPort}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="DrawerPortBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="{DynamicResource Set_ScalePort}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ScalePortBox" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12" VerticalAlignment="Center">
                            <CheckBox x:Name="AutoPrintCheckbox" Content="{DynamicResource Set_AutoPrint}" Margin="0,0,0,8"/>
                            <CheckBox x:Name="OpenDrawerCheckbox" Content="{DynamicResource Set_OpenDrawer}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{DynamicResource Set_TestPrint}" Style="{StaticResource OutlineButton}"
                                Click="TestPrint_Click" Padding="16,8" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Set_TestDrawer}" Style="{StaticResource OutlineButton}"
                                Click="TestDrawer_Click" Padding="16,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Language + theme -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Style="{StaticResource Heading3}" Margin="0,0,0,16">
                        <Run Text="{DynamicResource Set_Language}"/>
                        <Run Text=" &amp; "/>
                        <Run Text="{DynamicResource Set_Theme}"/>
                    </TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{DynamicResource Set_Language}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="LangEn" Content="{DynamicResource Set_English}" Margin="0,0,16,0" Checked="Lang_Checked"/>
                                <RadioButton x:Name="LangBn" Content="{DynamicResource Set_Bengali}" Checked="Lang_Checked"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="{DynamicResource Set_Theme}" Style="{StaticResource Muted}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="ThemeLight" Content="{DynamicResource Set_Light}" Margin="0,0,16,0" Checked="Theme_Checked"/>
                                <RadioButton x:Name="ThemeDark" Content="{DynamicResource Set_Dark}" Checked="Theme_Checked"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Button Content="{DynamicResource Set_Save}" Style="{StaticResource PrimaryButton}"
                            Click="Save_Click" Padding="24,12" HorizontalAlignment="Right" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
