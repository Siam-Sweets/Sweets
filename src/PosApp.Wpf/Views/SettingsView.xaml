<UserControl x:Class="PosApp.Wpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="SettingsTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextDarkBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/></Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions><Condition Property="IsSelected" Value="True"/><Condition Property="IsMouseOver" Value="True"/></MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource Set_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Set_NewSubtitle}" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="SettingsTabs" Grid.Row="1" TabStripPlacement="Left" Background="Transparent" BorderThickness="0" Padding="0">
            <TabControl.Resources><Style TargetType="TabItem" BasedOn="{StaticResource SettingsTab}"/></TabControl.Resources>

            <TabItem Header="{DynamicResource Set_General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_ApplicationStyle}" Style="{StaticResource Heading2}" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="{DynamicResource Set_Language}" Style="{StaticResource Muted}" Margin="0,0,0,7"/>
                                        <StackPanel Orientation="Horizontal"><RadioButton x:Name="LangEn" Content="{DynamicResource Set_English}" Margin="0,0,18,0" Checked="Lang_Checked"/><RadioButton x:Name="LangBn" Content="{DynamicResource Set_Bengali}" Checked="Lang_Checked"/></StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{DynamicResource Set_Theme}" Style="{StaticResource Muted}" Margin="0,0,0,7"/>
                                        <StackPanel Orientation="Horizontal"><RadioButton x:Name="ThemeLight" Content="{DynamicResource Set_Light}" Margin="0,0,18,0" Checked="Theme_Checked"/><RadioButton x:Name="ThemeDark" Content="{DynamicResource Set_Dark}" Checked="Theme_Checked"/></StackPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0"><TextBlock Text="{DynamicResource Set_UiScale}" Style="{StaticResource Muted}"/><ComboBox x:Name="UiScaleCombo" Margin="0,5,0,0" Padding="10,7"><ComboBoxItem Content="90%"/><ComboBoxItem Content="100%"/><ComboBoxItem Content="110%"/><ComboBoxItem Content="125%"/></ComboBox></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0"><TextBlock Text="{DynamicResource Set_MessageDuration}" Style="{StaticResource Muted}"/><TextBox x:Name="MessageDurationBox" Margin="0,5,0,0" Padding="10,7"/></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_Store}" Style="{StaticResource Heading2}" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="0,0,8,12"><TextBlock Text="{DynamicResource Set_StoreName}" Style="{StaticResource Muted}"/><TextBox x:Name="StoreNameBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,12"><TextBlock Text="{DynamicResource Set_Phone}" Style="{StaticResource Muted}"/><TextBox x:Name="PhoneBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,0,8,12"><TextBlock Text="{DynamicResource Set_Email}" Style="{StaticResource Muted}"/><TextBox x:Name="EmailBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12"><TextBlock Text="{DynamicResource Set_TaxId}" Style="{StaticResource Muted}"/><TextBox x:Name="TaxIdBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2"><TextBlock Text="{DynamicResource Set_Address}" Style="{StaticResource Muted}"/><TextBox x:Name="AddressBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0"><TextBlock Text="{DynamicResource Set_Currency}" Style="{StaticResource Muted}"/><TextBox x:Name="CurrencyBox" Width="180" HorizontalAlignment="Left" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="4" Margin="0,12,8,0"><TextBlock Text="{DynamicResource Set_Country}" Style="{StaticResource Muted}"/><TextBox x:Name="CountryBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,12,0,0"><TextBlock Text="{DynamicResource Set_CurrencyCode}" Style="{StaticResource Muted}"/><TextBox x:Name="CurrencyCodeBox" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0"><TextBlock Text="{DynamicResource Set_CurrencyDecimals}" Style="{StaticResource Muted}"/><TextBox x:Name="CurrencyDecimalsBox" Width="180" HorizontalAlignment="Left" Padding="10,8" Margin="0,4,0,0"/></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_OrderPayment}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_OrderWorkflow}" Style="{StaticResource Heading2}" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,14"><TextBlock Text="{DynamicResource Set_DefaultService}" Style="{StaticResource Muted}"/><ComboBox x:Name="DefaultServiceCombo" Padding="10,7" Margin="0,5,0,0"><ComboBoxItem Content="{DynamicResource Service_Retail}" Tag="Retail"/><ComboBoxItem Content="{DynamicResource Service_Takeaway}" Tag="Takeaway"/><ComboBoxItem Content="{DynamicResource Service_Delivery}" Tag="Delivery"/><ComboBoxItem Content="{DynamicResource Service_DineIn}" Tag="Dine-in"/></ComboBox></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,14"><TextBlock Text="{DynamicResource Set_DefaultTax}" Style="{StaticResource Muted}"/><TextBox x:Name="DefaultTaxBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                </Grid>
                                <CheckBox x:Name="RequireOpenRegisterCheckbox" Content="{DynamicResource Set_RequireRegister}" Margin="0,6"/>
                                <CheckBox x:Name="ConfirmVoidCheckbox" Content="{DynamicResource Set_ConfirmVoid}" Margin="0,6"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_PaymentMethods}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Set_PaymentMethodsHelp}" Style="{StaticResource Muted}" Margin="0,5,0,14" TextWrapping="Wrap"/>
                                <UniformGrid Columns="4">
                                    <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="4" Padding="12" Margin="0,0,5,0"><TextBlock Text="{DynamicResource Pay_Cash}" HorizontalAlignment="Center" FontWeight="SemiBold"/></Border>
                                    <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="4" Padding="12" Margin="5,0"><TextBlock Text="{DynamicResource Pay_Card}" HorizontalAlignment="Center" FontWeight="SemiBold"/></Border>
                                    <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="4" Padding="12" Margin="5,0"><TextBlock Text="{DynamicResource Pay_Mobile}" HorizontalAlignment="Center" FontWeight="SemiBold"/></Border>
                                    <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="4" Padding="12" Margin="5,0,0,0"><TextBlock Text="{DynamicResource Pay_Bank}" HorizontalAlignment="Center" FontWeight="SemiBold"/></Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Nav_Products}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_ProductSearchLayout}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Set_ProductSearchHelp}" Style="{StaticResource Muted}" Margin="0,4,0,16" TextWrapping="Wrap"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,12"><TextBlock Text="{DynamicResource Set_Rows}" Style="{StaticResource Muted}"/><TextBox x:Name="GridRowsBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,12"><TextBlock Text="{DynamicResource Set_Columns}" Style="{StaticResource Muted}"/><TextBox x:Name="GridColumnsBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                </Grid>
                                <CheckBox x:Name="VirtualKeyboardCheckbox" Content="{DynamicResource Set_VirtualKeyboard}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_Documents}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_Receipt}" Style="{StaticResource Heading2}" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0"><TextBlock Text="{DynamicResource Set_Footer}" Style="{StaticResource Muted}"/><TextBox x:Name="FooterBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="{DynamicResource Set_ReceiptWidth}" Style="{StaticResource Muted}"/><TextBox x:Name="ReceiptWidthBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                </Grid>
                                <TextBlock Text="{DynamicResource Set_PrintFromHistory}" Style="{StaticResource Muted}"
                                           TextWrapping="Wrap" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_EmailSection}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="22"><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="{DynamicResource Set_EmailSection}" Style="{StaticResource Heading2}"/><TextBlock Text="{DynamicResource Set_OfflineEmail}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0"/></StackPanel></Border></StackPanel></ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_Cloud}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Cloud_Title}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Cloud_Help}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,16"/>
                                <TextBlock Text="{DynamicResource Cloud_Endpoint}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="CloudEndpointBox" Padding="10,8" Margin="0,5,0,4"/>
                                <TextBlock Text="{DynamicResource Cloud_EndpointHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                    <StackPanel Margin="0,0,10,12"><TextBlock Text="{DynamicResource Cloud_Email}" Style="{StaticResource Muted}"/><TextBox x:Name="CloudEmailBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,12"><TextBlock Text="{DynamicResource Cloud_Password}" Style="{StaticResource Muted}"/><PasswordBox x:Name="CloudPasswordBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Margin="0,0,10,12"><TextBlock Text="{DynamicResource Cloud_DisplayName}" Style="{StaticResource Muted}"/><TextBox x:Name="CloudDisplayNameBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12"><TextBlock Text="{DynamicResource Cloud_DeviceName}" Style="{StaticResource Muted}"/><TextBox x:Name="CloudDeviceNameBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2"><TextBlock Text="{DynamicResource Cloud_RegistrationKey}" Style="{StaticResource Muted}"/><PasswordBox x:Name="CloudRegistrationKeyBox" Padding="10,8" Margin="0,5,0,0"/></StackPanel>
                                </Grid>
                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="{DynamicResource Cloud_Test}" Style="{StaticResource OutlineButton}" Click="CloudTest_Click" Padding="15,9" Margin="0,0,8,8"/>
                                    <Button Content="{DynamicResource Cloud_SignUp}" Style="{StaticResource PrimaryButton}" Click="CloudSignUp_Click" Padding="15,9" Margin="0,0,8,8"/>
                                    <Button Content="{DynamicResource Cloud_SignIn}" Style="{StaticResource SuccessButton}" Click="CloudSignIn_Click" Padding="15,9" Margin="0,0,8,8"/>
                                    <Button Content="{DynamicResource Cloud_Disconnect}" Style="{StaticResource OutlineButton}" Click="CloudDisconnect_Click" Padding="15,9" Margin="0,0,8,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Cloud_Status}" Style="{StaticResource Heading3}"/>
                                <TextBlock x:Name="CloudStatusText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,14"/>
                                <TextBlock Text="{DynamicResource Cloud_SyncHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Button x:Name="CloudSyncNowButton" Content="{DynamicResource Cloud_SyncNow}" Style="{StaticResource PrimaryButton}" Click="CloudSyncNow_Click" Padding="18,10" Margin="0,0,8,8"/>
                                    <Button x:Name="CloudSyncCenterButton" Content="{DynamicResource SyncCenter_Open}" Style="{StaticResource OutlineButton}" Click="CloudSyncCenter_Click" Padding="18,10" Margin="0,0,8,8"/>
                                    <Button x:Name="CloudUploadSnapshotButton" Content="{DynamicResource Cloud_UploadSnapshot}" Style="{StaticResource OutlineButton}" Click="CloudUploadSnapshot_Click" Padding="18,10" Margin="0,0,8,8"/>
                                    <Button x:Name="CloudRestoreButton" Content="{DynamicResource Cloud_Restore}" Style="{StaticResource OutlineButton}" Click="CloudRestore_Click" Padding="18,10" Margin="0,0,8,8"/>
                                </WrapPanel>
                                <TextBlock Text="{DynamicResource Cloud_RestoreHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_Print}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_Print}" Style="{StaticResource Heading2}" Margin="0,0,0,16"/>
                                <TextBlock Text="{DynamicResource Set_Printer}" Style="{StaticResource Muted}"/>
                                <ComboBox x:Name="PrinterCombo" Padding="10,8" Margin="0,5,0,14"/>
                                <Button Content="{DynamicResource Set_TestPrint}" Style="{StaticResource OutlineButton}" Click="TestPrint_Click" Padding="18,9" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_Database}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_DataSafety}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Set_BackupDescription}" Style="{StaticResource Muted}" Margin="0,5,0,16" TextWrapping="Wrap"/>
                                <CheckBox x:Name="AutoBackupCheckbox" Content="{DynamicResource Set_AutoBackup}" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal" Margin="20,0,0,10"><CheckBox x:Name="BackupStartupCheckbox" Content="{DynamicResource Set_OnStartup}" Margin="0,0,20,0"/><CheckBox x:Name="BackupExitCheckbox" Content="{DynamicResource Set_OnExit}"/></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="20,0,0,14"><TextBlock Text="{DynamicResource Set_KeepLatest}" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox x:Name="BackupRetentionBox" Width="70" Padding="8,6"/><TextBlock Text="{DynamicResource Set_AutomaticBackups}" VerticalAlignment="Center" Margin="8,0,0,0"/></StackPanel>
                                <TextBlock Text="{DynamicResource Set_BackupFolder}" Style="{StaticResource Muted}"/><TextBlock x:Name="BackupFolderText" TextWrapping="Wrap" Margin="0,4,0,14"/>
                                <WrapPanel><Button Content="{DynamicResource Set_BackupNow}" Style="{StaticResource PrimaryButton}" Click="BackupNow_Click" Padding="15,9" Margin="0,0,8,8"/><Button Content="{DynamicResource Set_Restore}" Style="{StaticResource OutlineButton}" Click="Restore_Click" Padding="15,9" Margin="0,0,8,8"/><Button Content="{DynamicResource Set_OpenFolder}" Style="{StaticResource OutlineButton}" Click="OpenBackupFolder_Click" Padding="15,9" Margin="0,0,8,8"/></WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_Update}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_SafeUpdate}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Set_SafeUpdateHelp}" Style="{StaticResource Muted}"
                                           TextWrapping="Wrap" Margin="0,6,0,18"/>
                                <TextBlock Text="{DynamicResource Set_CurrentVersion}" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="CurrentVersionText" FontSize="22" FontWeight="Bold" Margin="0,3,0,14"/>
                                <TextBlock Text="{DynamicResource Set_UpdateStatus}" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="UpdateStatusText" TextWrapping="Wrap" Margin="0,4,0,14"/>
                                <TextBlock Text="{DynamicResource Set_SelectedInstaller}" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="SelectedInstallerText" TextWrapping="Wrap" Margin="0,4,0,16"/>
                                <WrapPanel>
                                    <Button Content="{DynamicResource Set_ChooseUpdate}" Style="{StaticResource PrimaryButton}"
                                            Click="SelectUpdate_Click" Padding="18,10" Margin="0,0,8,8"/>
                                    <Button Content="{DynamicResource Set_OpenUpdateBackups}" Style="{StaticResource OutlineButton}"
                                            Click="OpenUpdateBackups_Click" Padding="18,10" Margin="0,0,8,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Set_UpdateProtection}" Style="{StaticResource Heading3}"/>
                                <TextBlock Text="{DynamicResource Set_UpdateProtectionHelp}" Style="{StaticResource Muted}"
                                           TextWrapping="Wrap" Margin="0,7,0,14"/>
                                <TextBlock Text="{DynamicResource Set_DataFolder}" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="UpdateDataFolderText" TextWrapping="Wrap" Margin="0,3,0,12"/>
                                <TextBlock Text="{DynamicResource Set_UpdateBackupFolder}" Style="{StaticResource Muted}"/>
                                <TextBlock x:Name="UpdateBackupFolderText" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource Set_About}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="22"><Border Style="{StaticResource Card}"><StackPanel><Image Source="/PosApp;component/Assets/PosAppLogo.png" Width="72" Height="72" HorizontalAlignment="Left"/><TextBlock Text="PosApp" FontSize="26" FontWeight="Bold" Margin="0,12,0,0"/><TextBlock x:Name="AboutVersionText" Style="{StaticResource Muted}" Margin="0,4,0,0"/><TextBlock Text="{DynamicResource Set_OfflineAbout}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,14,0,0"/></StackPanel></Border></StackPanel></ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,12">
            <Button Content="{DynamicResource Set_Save}" Style="{StaticResource SuccessButton}" Click="Save_Click" Padding="28,11" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</UserControl>
