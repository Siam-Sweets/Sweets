<UserControl x:Class="PosApp.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:UserRoleToStringConverter x:Key="RoleStr"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Usr_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Manage cashier, manager, and admin accounts with role-based permissions" Style="{StaticResource Muted}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource Usr_Add}" Style="{StaticResource PrimaryButton}"
                    Click="Add_Click" Padding="20,12"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="160"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="Role" Binding="{Binding Role, Converter={StaticResource RoleStr}}" Width="120"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
                    <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="160"/>
                    <DataGridTemplateColumn Header="Actions" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Edit" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Edit_Click" Tag="{Binding}"/>
                                    <Button Content="Reset PIN" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="ResetPin_Click" Tag="{Binding}"/>
                                    <Button Content="Delete" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Margin="2" Click="Delete_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
