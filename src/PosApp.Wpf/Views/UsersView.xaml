<UserControl x:Class="PosApp.Wpf.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:UserRoleToStringConverter x:Key="RoleStr"/>
        <conv:UtcToLocalConverter x:Key="UtcToLocal"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource Usr_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Usr_Subtitle}" Style="{StaticResource Muted}"/>
                <TextBlock x:Name="OnlineModeHint" Text="{DynamicResource Cloud_UserManagementHint}"
                           Foreground="{DynamicResource InfoTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0" Visibility="Collapsed"/>
            </StackPanel>
            <Button x:Name="AddUserButton" Grid.Column="1" Content="{DynamicResource Usr_Add}" Style="{StaticResource PrimaryButton}"
                    Click="Add_Click" Padding="20,12"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Usr_Username}" Binding="{Binding Username}" Width="160"/>
                    <DataGridTextColumn Header="{DynamicResource Usr_FullName}" Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="{DynamicResource Usr_Role}" Binding="{Binding Role, Converter={StaticResource RoleStr}}" Width="120"/>
                    <DataGridTemplateColumn Header="{DynamicResource Usr_Active}" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}"
                                          Tag="{Binding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Focusable="False"
                                          PreviewMouseLeftButtonDown="Active_PreviewMouseLeftButtonDown"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource Usr_LastLogin}" Binding="{Binding LastLoginAt, Converter={StaticResource UtcToLocal}, ConverterParameter=yyyy-MM-dd HH:mm}" Width="160"/>
                    <DataGridTemplateColumn Header="{DynamicResource Common_Actions}" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource Usr_Edit}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Edit_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource Usr_ResetPin}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="ResetPin_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource Usr_Delete}" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Margin="2" Click="Delete_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
