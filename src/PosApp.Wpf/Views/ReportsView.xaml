<UserControl x:Class="PosApp.Wpf.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:MoneyConverter x:Key="Money"/>
        <conv:PaymentMethodToStringConverter x:Key="PayStr"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rpt_Title}" Style="{StaticResource Heading1}"/>
                    <TextBlock Text="{DynamicResource Rpt_Subtitle}" Style="{StaticResource Muted}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{DynamicResource Common_Print}" Style="{StaticResource OutlineButton}"
                        Click="Print_Click" Padding="18,9" VerticalAlignment="Center"/>
            </Grid>

            <!-- Period selector -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                <Button x:Name="BtnToday" Style="{StaticResource PrimaryButton}" Content="{DynamicResource Rpt_Today}"
                        Click="Period_Click" Tag="today" Margin="0,0,4,0" Padding="16,8"/>
                <Button x:Name="BtnWeek" Style="{StaticResource OutlineButton}" Content="{DynamicResource Rpt_Week}"
                        Click="Period_Click" Tag="week" Margin="4,0" Padding="16,8"/>
                <Button x:Name="BtnMonth" Style="{StaticResource OutlineButton}" Content="{DynamicResource Rpt_Month}"
                        Click="Period_Click" Tag="month" Margin="4,0" Padding="16,8"/>
                <TextBlock Text="{DynamicResource Rpt_From}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker x:Name="FromDate" Width="140"/>
                <TextBlock Text="{DynamicResource Rpt_To}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker x:Name="ToDate" Width="140"/>
                <Button Content="{DynamicResource Rpt_Apply}" Style="{StaticResource PrimaryButton}" Click="Apply_Click"
                        Margin="8,0,0,0" Padding="16,8"/>
                <TextBlock Text="{DynamicResource Transfer_Store}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox x:Name="StoreFilter" Width="200" DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="StoreFilter_Changed"/>
            </StackPanel>

            <!-- KPI cards -->
            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_GrossSales}" Style="{StaticResource Muted}"/>
                        <TextBlock x:Name="KpiGross" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="8,0" Background="{DynamicResource SuccessSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_Profit}" Style="{StaticResource Muted}"/>
                        <TextBlock x:Name="KpiProfit" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SuccessTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="8,0" Background="{DynamicResource InfoSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_TaxCollected}" Style="{StaticResource Muted}"/>
                        <TextBlock x:Name="KpiTax" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource InfoTextBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_Transactions}" Style="{StaticResource Muted}"/>
                        <TextBlock x:Name="KpiTxn" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts + tables -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top products -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_TopProducts}" Style="{StaticResource Heading3}" Margin="0,0,0,12"/>
                        <DataGrid x:Name="TopProductsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Height="240" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Product}" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Qty}" Binding="{Binding QuantitySold}" Width="50"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Revenue}" Binding="{Binding Revenue, Converter={StaticResource Money}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Sales by category -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_ByCategory}" Style="{StaticResource Heading3}" Margin="0,0,0,12"/>
                        <DataGrid x:Name="CategoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Height="240" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Category}" Binding="{Binding CategoryName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Qty}" Binding="{Binding QuantitySold}" Width="60"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Revenue}" Binding="{Binding Revenue, Converter={StaticResource Money}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Daily trend -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_DailyTrend}" Style="{StaticResource Heading3}" Margin="0,0,0,12"/>
                        <DataGrid x:Name="DailyTrendGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Height="240" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Date}" Binding="{Binding Date, StringFormat='yyyy-MM-dd'}" Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Txns}" Binding="{Binding TransactionCount}" Width="60"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Items}" Binding="{Binding ItemCount}" Width="60"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Net}" Binding="{Binding NetSales, Converter={StaticResource Money}}" Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Profit}" Binding="{Binding GrossProfit, Converter={StaticResource Money}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Payment breakdown -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Rpt_ByPayment}" Style="{StaticResource Heading3}" Margin="0,0,0,12"/>
                        <DataGrid x:Name="PaymentGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Height="240" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Method}" Binding="{Binding Method, Converter={StaticResource PayStr}}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Count}" Binding="{Binding Count}" Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Total}" Binding="{Binding Total, Converter={StaticResource Money}}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Report_ByStore}" Style="{StaticResource Heading3}" Margin="0,0,0,12"/>
                        <DataGrid x:Name="StorePerformanceGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Store_Code}" Binding="{Binding StoreCode}" Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource Transfer_Store}" Binding="{Binding StoreName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Transactions}" Binding="{Binding TransactionCount}" Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_NetSales}" Binding="{Binding NetSales, Converter={StaticResource Money}}" Width="140"/>
                                <DataGridTextColumn Header="{DynamicResource Rpt_Profit}" Binding="{Binding GrossProfit, Converter={StaticResource Money}}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
