<UserControl x:Class="PosApp.Wpf.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:StockColorConverter x:Key="StockColor"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Inv_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Track stock levels, make adjustments, and review movement history" Style="{StaticResource Muted}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Inventory Count" Style="{StaticResource PrimaryButton}"
                    Click="InventoryCount_Click" VerticalAlignment="Center"/>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Total Products" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TotalProductsText" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0" Background="{DynamicResource DangerSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Inv_LowStock}" Style="{StaticResource Muted}" Foreground="{DynamicResource DangerTextBrush}"/>
                    <TextBlock x:Name="LowStockText" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource DangerTextBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0" Background="{DynamicResource SuccessSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="Stock Value (Cost)" Style="{StaticResource Muted}" Foreground="{DynamicResource SuccessTextBrush}"/>
                    <TextBlock x:Name="StockValueText" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessTextBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Stock levels -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0" Padding="0">
                <DockPanel>
                    <TextBlock Text="Current Stock Levels" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="StockGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="100"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity, StringFormat=' {0:0.###}'}" Width="80"/>
                            <DataGridTextColumn Header="Threshold" Binding="{Binding LowStockThreshold, StringFormat=' {0}'}" Width="80"/>
                            <DataGridTemplateColumn Header="Adjust" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Adjust" Style="{StaticResource OutlineButton}"
                                                Padding="8,4" Margin="2" Click="Adjust_Click" Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Low stock + recent history -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0" Padding="0">
                <DockPanel>
                    <TextBlock Text="Recent Stock Movements" DockPanel.Dock="Top" FontWeight="SemiBold" Margin="16,16,16,8"/>
                    <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, StringFormat=' {0:0.###}'}" Width="60"/>
                            <DataGridTextColumn Header="Balance" Binding="{Binding BalanceAfter, StringFormat=' {0:0.###}'}" Width="70"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=' {0:MM-dd HH:mm}'}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
