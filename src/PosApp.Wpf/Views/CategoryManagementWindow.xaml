<Window x:Class="PosApp.Wpf.Views.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Cat_Title}"
        Icon="/PosApp;component/Assets/PosApp.ico"
        Width="900" Height="590" MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource Cat_Title}" Style="{StaticResource Heading1}"/>
                <TextBlock Text="{DynamicResource Cat_Subtitle}" Style="{StaticResource Muted}"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1" Content="{DynamicResource Cat_New}"
                    Style="{StaticResource PrimaryButton}" Padding="18,10"
                    Click="New_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="360"/>
                <ColumnDefinition Width="2*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,12,0">
                <DataGrid x:Name="CategoriesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionChanged="CategoriesGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Cat_Name}" Binding="{Binding Name}"
                                            Width="150" MinWidth="120"/>
                        <DataGridTextColumn Header="{DynamicResource Cat_Description}" Binding="{Binding Description}"
                                            Width="*" MinWidth="150"/>
                        <DataGridTextColumn Header="{DynamicResource Cat_Color}" Binding="{Binding Color}"
                                            Width="95"/>
                        <DataGridTextColumn Header="{DynamicResource Cat_SortOrder}" Binding="{Binding SortOrder}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="EditorTitle" Text="{DynamicResource Cat_EditorNew}"
                                   Style="{StaticResource Heading2}" Margin="0,0,0,14"/>

                        <TextBlock Text="{DynamicResource Cat_Name}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="NameBox" Margin="0,5,0,12" Padding="10,8" MaxLength="100"/>

                        <TextBlock Text="{DynamicResource Cat_Description}" Style="{StaticResource Muted}"/>
                        <TextBox x:Name="DescriptionBox" Margin="0,5,0,12" Padding="10,8"
                                 MaxLength="500" MinHeight="74" AcceptsReturn="True"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="{DynamicResource Cat_Color}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="ColorBox" Margin="0,5,0,0" Padding="10,8" MaxLength="7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="{DynamicResource Cat_SortOrder}" Style="{StaticResource Muted}"/>
                                <TextBox x:Name="SortOrderBox" Margin="0,5,0,0" Padding="10,8" MaxLength="10"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{DynamicResource Cat_ColorHelp}" Style="{StaticResource Muted}"
                                   TextWrapping="Wrap" Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="DeleteButton" Content="{DynamicResource Common_Delete}"
                                    Style="{StaticResource DangerButton}" Padding="12,9"
                                    Margin="0,0,5,0" Click="Delete_Click" IsEnabled="False"/>
                            <Button Grid.Column="1" Content="{DynamicResource Common_Save}"
                                    Style="{StaticResource PrimaryButton}" Padding="12,9"
                                    Margin="5,0,0,0" Click="Save_Click"/>
                        </Grid>

                        <TextBlock x:Name="StatusText" Foreground="{DynamicResource InfoTextBrush}"
                                   TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Button Grid.Row="2" Content="{DynamicResource Common_Close}"
                Style="{StaticResource OutlineButton}" HorizontalAlignment="Right"
                Padding="20,9" Margin="0,16,0,0" IsCancel="True" Click="Close_Click"/>
    </Grid>
</Window>
