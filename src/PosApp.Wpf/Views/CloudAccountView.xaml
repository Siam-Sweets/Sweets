<UserControl x:Class="PosApp.Wpf.Views.CloudAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource Cloud_OnlineSync}" Style="{StaticResource Heading1}"/>
                    <TextBlock Text="{DynamicResource Cloud_OnlineSyncSubtitle}" Style="{StaticResource Muted}" Margin="0,3,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource Cloud_ManualSync}" Style="{StaticResource PrimaryButton}"
                            Padding="18,10" Margin="0,0,8,0" Click="SyncNow_Click"/>
                    <Button Content="{DynamicResource Cloud_Retry}" Style="{StaticResource OutlineButton}"
                            Padding="18,10" Click="Retry_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Cloud_CurrentAccount}" Style="{StaticResource Heading2}"/>
                                <TextBlock x:Name="OrganizationText" FontSize="18" FontWeight="SemiBold" Margin="0,7,0,0"/>
                                <TextBlock x:Name="EndpointText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="StatusPill" Background="{DynamicResource SurfaceMutedBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="13,6" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock x:Name="StatusLabel" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <UniformGrid Columns="4" Margin="0,18,0,0">
                            <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="13" Margin="0,0,6,0">
                                <StackPanel><TextBlock Text="{DynamicResource Cloud_LastSync}" Style="{StaticResource Muted}"/><TextBlock x:Name="LastSyncText" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel>
                            </Border>
                            <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="13" Margin="6,0">
                                <StackPanel><TextBlock Text="{DynamicResource Cloud_PendingUploads}" Style="{StaticResource Muted}"/><TextBlock x:Name="PendingText" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
                            </Border>
                            <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="13" Margin="6,0">
                                <StackPanel><TextBlock Text="{DynamicResource Cloud_Conflicts}" Style="{StaticResource Muted}"/><TextBlock x:Name="ConflictCountText" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
                            </Border>
                            <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="13" Margin="6,0,0,0">
                                <StackPanel><TextBlock Text="{DynamicResource Cloud_Store}" Style="{StaticResource Muted}"/><TextBlock x:Name="CurrentStoreText" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                            </Border>
                        </UniformGrid>
                        <ProgressBar x:Name="SyncProgress" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,14,0,0"/>
                        <TextBlock x:Name="ErrorDetailsText" Foreground="{DynamicResource DangerTextBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Cloud_OrganizationProfiles}" Style="{StaticResource Heading2}"/>
                            <TextBlock x:Name="OrganizationProfileHelpText"
                                       Text="{DynamicResource Cloud_OrganizationProfilesHelp}"
                                       Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,18,0"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <ComboBox x:Name="OrganizationProfilesCombo" Width="250" DisplayMemberPath="DisplayName"
                                      Padding="9,7" Margin="0,0,8,0"/>
                            <Button Content="{DynamicResource Cloud_SwitchOrganization}" Style="{StaticResource OutlineButton}"
                                    Padding="15,9" Margin="0,0,8,0" Click="SwitchOrganization_Click"/>
                            <Button Content="{DynamicResource Cloud_AddOrganization}" Style="{StaticResource PrimaryButton}"
                                    Padding="15,9" Click="AddOrganization_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border x:Name="ReconciliationCard" Style="{StaticResource Card}" Margin="0,14,0,0" Background="{DynamicResource DangerSurfaceBrush}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Cloud_ReconciliationTitle}" Style="{StaticResource Heading2}" Foreground="{DynamicResource DangerTextBrush}"/>
                        <TextBlock Text="{DynamicResource Cloud_ReconciliationHelp}" TextWrapping="Wrap" Margin="0,7,0,14"/>
                        <TextBlock x:Name="ReconciliationBackupText" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                        <WrapPanel>
                            <Button Content="{DynamicResource Cloud_UseServerData}" Style="{StaticResource PrimaryButton}" Padding="16,9" Margin="0,0,8,8" Click="UseServerAfterRestore_Click"/>
                            <Button Content="{DynamicResource Cloud_UploadRestoredData}" Style="{StaticResource OutlineButton}" Padding="16,9" Margin="0,0,8,8" Click="UploadRestored_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Cloud_Stores}" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="{DynamicResource Cloud_StoresHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox x:Name="StoreCombo" Width="330" DisplayMemberPath="Name" Padding="10,8"/>
                            <Button Content="{DynamicResource Cloud_SwitchStore}" Style="{StaticResource OutlineButton}" Padding="16,9" Margin="10,0,0,0" Click="SwitchStore_Click"/>
                        </StackPanel>
                        <Grid x:Name="CreateStorePanel" Margin="0,14,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="220"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="{DynamicResource Cloud_NewStoreName}" Style="{StaticResource Muted}"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Cloud_StoreCode}" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="NewStoreNameBox" Grid.Row="1" Padding="9,7" MaxLength="160"/>
                            <TextBox x:Name="NewStoreCodeBox" Grid.Row="1" Grid.Column="2" Padding="9,7" MaxLength="20"/>
                            <Button Grid.Row="1" Grid.Column="3" Content="{DynamicResource Cloud_CreateStore}" Style="{StaticResource PrimaryButton}"
                                    Padding="16,9" Margin="10,0,0,0" Click="CreateStore_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="OnlineUsersCard" Style="{StaticResource Card}" Margin="0,14,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Cloud_OnlineUsers}" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{DynamicResource Cloud_OnlineUsersHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="{DynamicResource Cloud_Refresh}" Style="{StaticResource OutlineButton}" Padding="14,8" Click="RefreshUsers_Click"/>
                        </Grid>
                        <DataGrid x:Name="OnlineUsersGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="240"
                                  SelectionMode="Single" SelectionChanged="OnlineUsersGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Cloud_Username}" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_FullName}" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_Email}" Binding="{Binding Email}" Width="220"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_Role}" Binding="{Binding Role}" Width="100"/>
                                <DataGridCheckBoxColumn Header="{DynamicResource Cloud_Active}" Binding="{Binding IsActive}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel Margin="0,10,0,0">
                            <ComboBox x:Name="OnlineUserRoleCombo" Width="150" DisplayMemberPath="Label" Padding="9,7" Margin="0,0,8,8"/>
                            <CheckBox x:Name="OnlineUserActiveCheck" Content="{DynamicResource Cloud_Active}" VerticalAlignment="Center" Margin="0,0,12,8"/>
                            <Button Content="{DynamicResource Cloud_ApplyUserChanges}" Style="{StaticResource OutlineButton}" Padding="15,9" Margin="0,0,8,8" Click="ApplyUserChanges_Click"/>
                        </WrapPanel>
                        <Separator Margin="0,10"/>
                        <TextBlock Text="{DynamicResource Cloud_CreateOnlineUser}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="{DynamicResource Cloud_Username}" Style="{StaticResource Muted}"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Cloud_Email}" Style="{StaticResource Muted}"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Cloud_FullName}" Style="{StaticResource Muted}"/>
                            <TextBox x:Name="NewUsernameBox" Grid.Row="1" Padding="9,7" MaxLength="60"/>
                            <TextBox x:Name="NewEmailBox" Grid.Row="1" Grid.Column="2" Padding="9,7" MaxLength="255"/>
                            <TextBox x:Name="NewFullNameBox" Grid.Row="1" Grid.Column="4" Padding="9,7" MaxLength="100"/>
                            <TextBlock Grid.Row="2" Text="{DynamicResource Cloud_InitialPassword}" Style="{StaticResource Muted}" Margin="0,9,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{DynamicResource Cloud_Role}" Style="{StaticResource Muted}" Margin="0,9,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Text="{DynamicResource Cloud_AssignedStore}" Style="{StaticResource Muted}" Margin="0,9,0,0"/>
                            <PasswordBox x:Name="NewUserPasswordBox" Grid.Row="3" Padding="9,7" MaxLength="128"/>
                            <ComboBox x:Name="NewUserRoleCombo" Grid.Row="3" Grid.Column="2" DisplayMemberPath="Label" Padding="9,7"/>
                            <ComboBox x:Name="NewUserStoreCombo" Grid.Row="3" Grid.Column="4" DisplayMemberPath="Name" Padding="9,7"/>
                        </Grid>
                        <Button Content="{DynamicResource Cloud_CreateUser}" Style="{StaticResource PrimaryButton}" Padding="16,9"
                                HorizontalAlignment="Left" Margin="0,12,0,0" Click="CreateUser_Click"/>
                    </StackPanel>
                </Border>

                <Border x:Name="InitialMigrationCard" Style="{StaticResource Card}" Margin="0,14,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Cloud_InitialMigration}" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="{DynamicResource Cloud_InitialMigrationHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,12"/>
                        <TextBlock x:Name="MigrationSummaryText" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="{DynamicResource Cloud_CheckMigration}" Style="{StaticResource OutlineButton}" Padding="16,9" Margin="0,0,8,8" Click="PreviewMigration_Click"/>
                            <Button x:Name="UploadExistingButton" Content="{DynamicResource Cloud_UploadExisting}" Style="{StaticResource PrimaryButton}" Padding="16,9" Margin="0,0,8,8" Click="UploadExisting_Click" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="{DynamicResource Cloud_DeviceSessions}" Style="{StaticResource Heading2}"/><TextBlock Text="{DynamicResource Cloud_DeviceSessionsHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
                            <Button Grid.Column="1" Content="{DynamicResource Cloud_Refresh}" Style="{StaticResource OutlineButton}" Padding="14,8" Click="RefreshDevices_Click"/>
                        </Grid>
                        <DataGrid x:Name="DevicesGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="280" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Cloud_DeviceName}" Binding="{Binding DeviceName}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_Username}" Binding="{Binding Username}" Width="140"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_AssignedStore}" Binding="{Binding StoreName}" Width="160"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_OperatingSystem}" Binding="{Binding OperatingSystem}" Width="220"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_LastLogin}" Binding="{Binding LastLoginAtUtc, StringFormat=g}" Width="155"/>
                                <DataGridCheckBoxColumn Header="{DynamicResource Cloud_Current}" Binding="{Binding IsCurrent}" Width="80"/>
                                <DataGridCheckBoxColumn Header="{DynamicResource Cloud_Revoked}" Binding="{Binding IsRevoked}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="{DynamicResource Cloud_RevokeSelected}" Style="{StaticResource DangerButton}" Padding="15,9" Margin="0,0,8,8" Click="RevokeSession_Click"/>
                            <Button x:Name="RevokeDeviceButton" Content="{DynamicResource Cloud_RevokeDevice}" Style="{StaticResource DangerButton}" Padding="15,9" Margin="0,0,8,8" Click="RevokeDevice_Click" Visibility="Collapsed"/>
                            <Button x:Name="AuthorizeDeviceButton" Content="{DynamicResource Cloud_AuthorizeDevice}" Style="{StaticResource OutlineButton}" Padding="15,9" Margin="0,0,8,8" Click="AuthorizeDevice_Click" Visibility="Collapsed"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Cloud_ConflictResolution}" Style="{StaticResource Heading2}"/>
                        <TextBlock Text="{DynamicResource Cloud_ConflictHelp}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,5,0,12"/>
                        <DataGrid x:Name="ConflictsGrid" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="240" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Cloud_RecordType}" Binding="{Binding EntityType}" Width="180"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_RecordId}" Binding="{Binding RecordId}" Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_Detected}" Binding="{Binding DetectedAtUtc, StringFormat=g}" Width="160"/>
                                <DataGridTextColumn Header="{DynamicResource Cloud_ServerVersion}" Binding="{Binding ServerVersion}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="{DynamicResource Cloud_KeepLocal}" Style="{StaticResource OutlineButton}" Padding="15,9" Margin="0,0,8,8" Click="KeepLocal_Click"/>
                            <Button Content="{DynamicResource Cloud_UseServer}" Style="{StaticResource OutlineButton}" Padding="15,9" Margin="0,0,8,8" Click="UseServer_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Cloud_Security}" Style="{StaticResource Heading2}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <PasswordBox x:Name="CurrentPasswordBox" Padding="10,8" Margin="0,0,8,0"/>
                            <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" Padding="10,8" Margin="8,0"/>
                            <Button Grid.Column="2" Content="{DynamicResource Cloud_ChangePassword}" Style="{StaticResource OutlineButton}" Padding="16,9" Margin="8,0,0,0" Click="ChangePassword_Click"/>
                        </Grid>
                        <Button Content="{DynamicResource Cloud_SecureLogout}" Style="{StaticResource DangerButton}" Padding="16,9" HorizontalAlignment="Left" Margin="0,16,0,0" Click="CloudLogout_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
