<UserControl x:Class="PosApp.Wpf.Views.PromotionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Promo_Title}" Style="{StaticResource Heading1}"/>
            <TextBlock Text="{DynamicResource Promo_Subtitle}" Style="{StaticResource Muted}"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="{DynamicResource Promo_Add}" Style="{StaticResource PrimaryButton}" Click="Add_Click" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Promo_Edit}" Style="{StaticResource OutlineButton}" Click="Edit_Click" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource Promo_Deactivate}" Style="{StaticResource DangerButton}" Click="Deactivate_Click"/>
        </StackPanel>
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="PromotionGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="PromotionGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Promo_Name}" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_Code}" Binding="{Binding Code}" Width="130"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_Type}" Binding="{Binding Type}" Width="130"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_Value}" Binding="{Binding Value, StringFormat={}{0:0.##}}" Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_ValidFrom}" Binding="{Binding ValidFrom, StringFormat='{}{0:dd MMM yyyy}'}" Width="135"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_ValidTo}" Binding="{Binding ValidTo, StringFormat='{}{0:dd MMM yyyy}'}" Width="135"/>
                    <DataGridTextColumn Header="{DynamicResource Promo_Uses}" Binding="{Binding UsageDisplay}" Width="100"/>
                    <DataGridCheckBoxColumn Header="{DynamicResource Promo_Active}" Binding="{Binding IsActive, Mode=OneWay}" Width="85"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
