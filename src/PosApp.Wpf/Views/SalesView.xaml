<UserControl x:Class="PosApp.Wpf.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:SaleStatusToStringConverter x:Key="StatusStr"/>
        <conv:MoneyConverter x:Key="Money"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Sales_Title}" Style="{StaticResource Heading1}"/>
            <TextBlock Text="Browse, filter, refund, void, and reprint past transactions" Style="{StaticResource Muted}"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Sales_From}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" x:Name="FromDate"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Sales_To}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker Grid.Column="3" x:Name="ToDate"/>
                <TextBlock Grid.Column="4" Text="{DynamicResource Sales_Status}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox Grid.Column="5" x:Name="StatusFilter" SelectedIndex="0">
                    <ComboBoxItem Content="All" Tag=""/>
                    <ComboBoxItem Content="Completed" Tag="Completed"/>
                    <ComboBoxItem Content="Suspended" Tag="Suspended"/>
                    <ComboBoxItem Content="Voided" Tag="Voided"/>
                    <ComboBoxItem Content="Refunded" Tag="Refunded"/>
                </ComboBox>
                <Button Grid.Column="6" Content="{DynamicResource Sales_Filter}" Style="{StaticResource PrimaryButton}"
                        Click="Filter_Click" Margin="16,0,0,0" Padding="16,8"/>
                <Button Grid.Column="7" Content="{DynamicResource Sales_Export}" Style="{StaticResource OutlineButton}"
                        Click="Export_Click" Margin="8,0,0,0" Padding="16,8"/>
            </Grid>
        </Border>

        <!-- Summary -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rpt_Transactions}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TxnCountText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0" Background="#EFF6FF">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rpt_GrossSales}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="GrossText" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0" Background="#FEF2F2">
                <StackPanel>
                    <TextBlock Text="{DynamicResource POS_Discount}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="DiscountText" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0" Background="#F0FDF4">
                <StackPanel>
                    <TextBlock Text="{DynamicResource POS_Tax}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TaxText" FontSize="22" FontWeight="Bold" Foreground="#15803D"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="SalesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      MouseDoubleClick="SalesGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Receipt" Binding="{Binding ReceiptNumber}" Width="140"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="140"/>
                    <DataGridTextColumn Header="Cashier" Binding="{Binding User.FullName}" Width="120"/>
                    <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="60"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat='৳ {0:0.00}'}" Width="100"/>
                    <DataGridTextColumn Header="Discount" Binding="{Binding DiscountTotal, StringFormat='- ৳ {0:0.00}'}" Width="100"/>
                    <DataGridTextColumn Header="Tax" Binding="{Binding TaxTotal, StringFormat='৳ {0:0.00}'}" Width="90"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat='৳ {0:0.00}'}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status, Converter={StaticResource StatusStr}}" Width="100"/>
                    <DataGridTemplateColumn Header="Actions" Width="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="View" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="View_Click" Tag="{Binding}"/>
                                    <Button Content="Print" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Print_Click" Tag="{Binding}"/>
                                    <Button Content="Refund" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Refund_Click" Tag="{Binding}"/>
                                    <Button Content="Void" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Margin="2" Click="Void_Click" Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
