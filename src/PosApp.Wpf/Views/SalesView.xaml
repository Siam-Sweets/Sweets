<UserControl x:Class="PosApp.Wpf.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PosApp.Wpf.Converters"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:SaleStatusToStringConverter x:Key="StatusStr"/>
        <conv:MoneyConverter x:Key="Money"/>
        <conv:UtcToLocalConverter x:Key="UtcToLocal"/>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Sales_Title}" Style="{StaticResource Heading1}"/>
            <TextBlock Text="{DynamicResource Sales_Subtitle}" Style="{StaticResource Muted}"/>
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{DynamicResource Sales_From}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1" x:Name="FromDate"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Sales_To}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <DatePicker Grid.Column="3" x:Name="ToDate"/>
                <TextBlock Grid.Column="4" Text="{DynamicResource Sales_Status}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                <ComboBox Grid.Column="5" x:Name="StatusFilter" SelectedIndex="0">
                    <ComboBoxItem Content="{DynamicResource Common_All}" Tag=""/>
                    <ComboBoxItem Content="{DynamicResource Sales_StatusCompleted}" Tag="Completed"/>
                    <ComboBoxItem Content="{DynamicResource Sales_StatusSuspended}" Tag="Suspended"/>
                    <ComboBoxItem Content="{DynamicResource Sales_StatusVoided}" Tag="Voided"/>
                    <ComboBoxItem Content="{DynamicResource Sales_StatusRefunded}" Tag="Refunded"/>
                </ComboBox>
                <Button Grid.Column="6" Content="{DynamicResource Sales_Filter}" Style="{StaticResource PrimaryButton}"
                        Click="Filter_Click" Margin="16,0,0,0" Padding="16,8"/>
                <Button Grid.Column="7" Content="{DynamicResource Sales_Export}" Style="{StaticResource OutlineButton}"
                        Click="Export_Click" Margin="8,0,0,0" Padding="16,8"/>
            </Grid>
        </Border>

        <!-- Summary -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rpt_Transactions}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TxnCountText" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0" Background="{DynamicResource InfoSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rpt_GrossSales}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="GrossText" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource InfoTextBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0" Background="{DynamicResource DangerSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource POS_Discount}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="DiscountText" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource DangerTextBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0" Background="{DynamicResource SuccessSurfaceBrush}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource POS_Tax}" Style="{StaticResource Muted}"/>
                    <TextBlock x:Name="TaxText" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SuccessTextBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="SalesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      MouseDoubleClick="SalesGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Sales_Receipt}" Binding="{Binding ReceiptNumber}" Width="140"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Date}" Binding="{Binding SaleDate, Converter={StaticResource UtcToLocal}, ConverterParameter=yyyy-MM-dd HH:mm}" Width="140"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Customer}" Binding="{Binding Customer.Name}" Width="140"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Cashier}" Binding="{Binding User.FullName}" Width="120"/>
                    <DataGridTextColumn Header="{DynamicResource Rpt_Items}" Binding="{Binding Items.Count}" Width="60"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Subtotal}" Binding="{Binding Subtotal, Converter={StaticResource Money}}" Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Discount}" Binding="{Binding DiscountTotal, Converter={StaticResource Money}}" Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Tax}" Binding="{Binding TaxTotal, Converter={StaticResource Money}}" Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource Rpt_Total}" Binding="{Binding Total, Converter={StaticResource Money}}" Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource Sales_Status}" Binding="{Binding Status, Converter={StaticResource StatusStr}}" Width="100"/>
                    <DataGridTemplateColumn Header="{DynamicResource Sales_Actions}" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{DynamicResource Common_View}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="View_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource Common_Print}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Print_Click" Tag="{Binding}"/>
                                    <Button Content="{DynamicResource POS_CustomRefund}" Style="{StaticResource OutlineButton}"
                                            Padding="8,4" Margin="2" Click="Refund_Click" Tag="{Binding}" IsEnabled="{Binding CanRefund}"/>
                                    <Button Content="{DynamicResource Sales_Void}" Style="{StaticResource DangerButton}"
                                            Padding="8,4" Margin="2" Click="Void_Click" Tag="{Binding}" IsEnabled="{Binding CanVoid}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
