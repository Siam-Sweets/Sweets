<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color palette: flat, modern, Material-inspired -->
    <Color x:Key="PrimaryColor">#2D7FF9</Color>
    <Color x:Key="PrimaryDarkColor">#1A5FBF</Color>
    <Color x:Key="AccentColor">#F59E0B</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="InfoColor">#3B82F6</Color>
    <Color x:Key="SidebarColor">#1E293B</Color>
    <Color x:Key="SidebarActiveColor">#0F172A</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="BackgroundLight">#F1F5F9</Color>
    <Color x:Key="TextDark">#0F172A</Color>
    <Color x:Key="TextMuted">#64748B</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundLight}"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="{StaticResource TextDark}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- Typography -->
    <FontFamily x:Key="DefaultFont">Segoe UI, Inter, Noto Sans, sans-serif</FontFamily>
    <FontFamily x:Key="BengaliFont">Noto Sans Bengali, SolaimanLipi, SutonnyMJ, Segoe UI</FontFamily>

    <!-- Sizes -->
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
    <Thickness x:Key="PagePadding">24</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>

    <Style x:Key="PageTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
    </Style>

</ResourceDictionary>
